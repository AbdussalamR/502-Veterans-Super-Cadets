# Enforce LF line endings for all text files
* text=auto eol=lf

# Ruby files
*.rb text eol=lf
*.rake text eol=lf
Gemfile text eol=lf
Rakefile text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.xml text eol=lf

# Web files
*.html text eol=lf
*.erb text eol=lf
*.js text eol=lf
*.css text eol=lf
*.scss text eol=lf

# Shell/system
Procfile text eol=lf
*.sh text eol=lf
