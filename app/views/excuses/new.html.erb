<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
          <h4 class="mb-0">Submit Excuse</h4>
        </div>
        <div class="card-body">
          <%# Date selector for filtering events %>
          <div class="mb-3">
            <label for="event-date-filter" class="form-label">Filter Events by Date</label>
            <input type="date" id="event-date-filter" class="form-control" />
          </div>
          <%= form_with model: @excuse, local: true, html: { id: "excuse-form" } do |form| %>
            <% if @excuse.errors.any? %>
              <div class="alert alert-danger">
                <h5><%= pluralize(@excuse.errors.count, "error") %> prohibited this excuse from being saved:</h5>
                <ul class="mb-0">
                  <% @excuse.errors.each do |error| %>
                    <li><%= error.full_message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="mb-3">
              <%= form.label :event_ids, "Events (select one or more)", class: "form-label" %>
              <select name="excuse[event_ids][]" id="excuse_event_ids" class="form-select" multiple size="6">
                <%# build an array of selected ids (supports single param :event_id or array :event_ids or existing @excuse.events) %>
                <% selected_ids = Array(params[:event_ids] || params[:event_id] || @excuse.events.map(&:id)).map(&:to_s) %>
                <% Event.all.order(date: :desc).each do |event| %>
                  <option value="<%= event.id %>" data-date="<%= event.date.strftime('%Y-%m-%d') %>" <%= 'selected' if selected_ids.include?(event.id.to_s) %>>
                    <%= event.title %> (<%= event.date.strftime('%B %d, %Y %I:%M %p') %>)
                  </option>
                <% end %>
              </select>
              <small class="form-text text-muted">Hold Ctrl (Cmd) to select multiple events.</small>
            </div>
            <div class="mb-3">
              <%= form.label :reason, class: "form-label" %>
              <%= form.text_area :reason, id: "excuse_reason", rows: 3, class: "form-control" %>
            </div>
            <div class="field mb-3">
              <%= form.label :proof_link, "Proof link (required)", class: "form-label" %>
              <%= form.text_field :proof_link, placeholder: "https://example.com/proof or Google Drive link", class: "form-control", id: "excuse_proof_link", required: true %>
              <small class="form-text text-muted">Paste a URL to your proof document or image.</small>
            </div>
            <div class="d-flex justify-content-between">
              <button type="button" class="btn btn-secondary" id="cancel-btn">Cancel</button>
              <%= form.submit "Submit Excuse", class: "btn btn-primary", id: "submit-btn" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const cancelBtn = document.getElementById("cancel-btn");
    const reasonField = document.getElementById("excuse_reason");
    const proofField = document.getElementById("excuse_proof_link");
    const form = document.getElementById("excuse-form");

    // Get event ids from params or @excuse (joined as comma-separated string)
    const initialEventIds = "<%= Array(params[:event_ids] || params[:event_id] || @excuse.events.map(&:id)).join(',') %>";

    cancelBtn.addEventListener("click", function() {
      const reasonNotEmpty = reasonField.value.trim() !== "";
      const proofNotEmpty = proofField && proofField.value.trim() !== "";

      let backUrl;
      const ids = initialEventIds ? initialEventIds.split(',') : [];
      if (ids.length === 1 && ids[0] !== "") {
        backUrl = "<%= url_for(controller: 'events', action: 'show', id: '') %>" + ids[0];
      } else {
        backUrl = "<%= excuses_path %>";
      }

      if (reasonNotEmpty || proofNotEmpty) {
        if (confirm("You have started filling out the form, are you sure you want to cancel? Your changes will be lost.")) {
          window.location.href = backUrl;
        }
      } else {
        window.location.href = backUrl;
      }
    });

    form.addEventListener("submit", function(event) {
      const reasonNotEmpty = reasonField.value.trim() !== "";
      const proofNotEmpty = proofField && proofField.value.trim() !== "";

      const eventSelect = document.getElementById("excuse_event_ids");
      const selectedCount = eventSelect ? eventSelect.selectedOptions.length : 0;

      if (!reasonNotEmpty || !proofNotEmpty || selectedCount === 0) {
        event.preventDefault();
        let messages = [];
        if (!reasonNotEmpty) messages.push("a reason");
        if (!proofNotEmpty) messages.push("a proof link");
        if (selectedCount === 0) messages.push("at least one event");
        alert("You must provide " + messages.join(" and ") + " before submitting.");
      }
    });

    // Date filter logic (works with multi-select)
    const dateFilter = document.getElementById("event-date-filter");
    const eventSelect = document.getElementById("excuse_event_ids");
    const allOptions = Array.from(eventSelect.options);

    dateFilter.addEventListener("change", function() {
      const selectedDate = dateFilter.value;
      // Capture currently selected option values so we can keep them visible
      const selectedValues = Array.from(eventSelect.selectedOptions).map(o => o.value);

      // clear and re-add matching options (retain original option objects by cloning)
      eventSelect.innerHTML = "";
      allOptions.forEach(option => {
        const optionDate = option.getAttribute("data-date");
        // Keep options that match date OR that are currently selected by the user
        if (!selectedDate || optionDate === selectedDate || selectedValues.includes(option.value)) {
          const clone = option.cloneNode(true);
          // preserve selection state for previously selected options
          if (selectedValues.includes(option.value)) {
            clone.selected = true;
          }
          eventSelect.appendChild(clone);
        }
      });

      // If only one event is available after filtering, select it
      if (eventSelect.options.length === 1) {
        eventSelect.selectedIndex = 0;
      }
    });

    // If an event is selected before picking a date, fill in the date field with the first selected
    eventSelect.addEventListener("change", function() {
      const selectedOption = eventSelect.options[eventSelect.selectedIndex];
      if (selectedOption && selectedOption.getAttribute("data-date")) {
        dateFilter.value = selectedOption.getAttribute("data-date");
      }
    });

    // On page load, if an event is pre-selected, set the date filter using the first selected
    const initialSelected = eventSelect.selectedOptions && eventSelect.selectedOptions[0];
    if (initialSelected && initialSelected.getAttribute("data-date") && dateFilter) {
      dateFilter.value = initialSelected.getAttribute("data-date");
      // trigger the change handler so the select is filtered immediately
      dateFilter.dispatchEvent(new Event('change', { bubbles: true }));
    }
  });
</script>