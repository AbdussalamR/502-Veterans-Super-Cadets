<h1><%= current_user.admin? && current_user != @user ? "Edit Member" : "Edit Profile & Notifications" %></h1>

<div class="card">
  <div class="card-body">
    <%= form_with model: @user, url: internal_user_path(@user), local: true, class: "row g-3" do |form| %>
      <% if @user.errors.any? %>
        <div class="alert alert-danger">
          <h4><%= pluralize(@user.errors.count, "error") %> prohibited this member from being saved:</h4>
          <ul class="mb-0">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="col-12">
        <%= form.label :full_name, class: "form-label" %>
        <%= form.text_field :full_name, class: "form-control" %>
      </div>

      <div class="col-12">
        <div class="form-text">
          <strong>Email:</strong> <%= @user.email %> (cannot be changed)
        </div>
      </div>

      <% if current_user.admin? %>
        <div class="col-12">
          <%= form.label :section_id, "Assign to Voice Section", class: "form-label fw-bold" %>
          <%= form.collection_select :section_id, Section.all, :id, :name, { include_blank: "No Section / Unassigned" }, class: "form-select" %>
          <div class="form-text">Officers can only review excuses for members in their assigned section.</div>
        </div>
      <% end %>

      <div class="col-12">
        <div class="form-check mt-4 pt-2">
          <%= form.check_box :email_notifications_enabled, class: "form-check-input" %>
          <%= form.label :email_notifications_enabled, "Email notifications enabled", class: "form-check-label" %>
        </div>
      </div>

      <div class="col-12">
        <div class="form-text">
          <strong>Current Role:</strong> 
          <span class="badge <%= 
            case @user.role
            when 'super_admin' then 'bg-danger'
            when 'officer' then 'bg-warning'
            else 'bg-secondary'
            end
          %>">
            <%= @user.role_display_name %>
          </span>
        </div>
      </div>

      <div class="col-12">
        <%= form.submit(current_user.admin? && current_user != @user ? "Update Member" : "Save Settings", class: "btn btn-primary") %>
        <%= link_to "Cancel", internal_user_path(@user), class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>

<div class="mt-3">
  <%= link_to 'Member Profile', internal_user_path(@user), class: 'btn btn-outline-primary' %>
  <%= link_to 'All Members', internal_users_path, class: 'btn btn-outline-secondary' %>
</div>
