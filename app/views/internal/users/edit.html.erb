<h1>Edit Member</h1>

<div class="card">
  <div class="card-body">
    <%= form_with model: @user, local: true, class: "row g-3" do |form| %>
      <% if @user.errors.any? %>
        <div class="alert alert-danger">
          <h4><%= pluralize(@user.errors.count, "error") %> prohibited this member from being saved:</h4>
          <ul class="mb-0">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="col-12">
        <%= form.label :full_name, class: "form-label" %>
        <%= form.text_field :full_name, class: "form-control" %>
      </div>

      <div class="col-12">
        <div class="form-text">
          <strong>Email:</strong> <%= @user.email %> (cannot be changed)
        </div>
      </div>

      <div class="col-12">
        <div class="form-text">
          <strong>Current Role:</strong> 
          <span class="badge <%= 
            case @user.role
            when 'super_admin' then 'bg-danger'
            when 'officer' then 'bg-warning'
            else 'bg-secondary'
            end
          %>">
            <%= @user.role_display_name %>
          </span>
        </div>
      </div>

      <div class="col-12">
        <%= form.submit "Update Member", class: "btn btn-primary" %>
        <%= link_to "Cancel", @user, class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>

<div class="mt-3">
  <%= link_to 'Member Profile', @user, class: 'btn btn-outline-primary' %>
  <%= link_to 'All Members', internal_users_path, class: 'btn btn-outline-secondary' %>
</div>
