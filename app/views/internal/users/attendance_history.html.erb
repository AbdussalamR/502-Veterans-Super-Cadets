<!-- Chart Script -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const canvas = document.getElementById('attendanceChart');
    if (canvas) {
      const ctx = canvas.getContext('2d');
      const percentage = <%= @attendance_stats[:present_percentage] %>;
      
      // Responsive sizing based on viewport
      const isMobile = window.innerWidth <= 768;
      const radius = isMobile ? 50 : 60;
      const centerX = isMobile ? 60 : 75;
      const centerY = isMobile ? 60 : 75;
      const lineWidth = isMobile ? 10 : 12;
      
      // Clear canvas
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      
      // Draw background circle
      ctx.beginPath();
      ctx.arc(centerX, centerY, radius, 0, 2 * Math.PI);
      ctx.strokeStyle = '#e9ecef';
      ctx.lineWidth = lineWidth;
      ctx.stroke();
      
      // Draw progress circle
      ctx.beginPath();
      ctx.arc(centerX, centerY, radius, -Math.PI / 2, (2 * Math.PI * percentage / 100) - Math.PI / 2);
      ctx.strokeStyle = '#0d6efd';
      ctx.lineWidth = lineWidth;
      ctx.lineCap = 'round';
      ctx.stroke();
    }
    
    // Redraw chart on orientation change
    window.addEventListener('orientationchange', function() {
      setTimeout(function() {
        location.reload();
      }, 200);
    });

    // Handle discipline card click - activate tab and scroll to it
    const disciplineCardLink = document.querySelector('.discipline-card-link');
    if (disciplineCardLink) {
      disciplineCardLink.addEventListener('click', function(e) {
        e.preventDefault();
        
        // Activate the discipline tab
        const demeritsTab = document.getElementById('demerits-tab');
        if (demeritsTab) {
          const bsTab = new bootstrap.Tab(demeritsTab);
          bsTab.show();
          
          // Scroll to the tab content after a short delay
          setTimeout(function() {
            const tabContent = document.getElementById('demerits');
            if (tabContent) {
              tabContent.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          }, 150);
        }
      });
    }
  });
</script>