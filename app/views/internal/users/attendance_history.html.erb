<!-- Breadcrumb Navigation -->
<nav aria-label="breadcrumb" class="mb-4">
  <ol class="breadcrumb">
    <% if current_user.admin? && @user != current_user %>
      <li class="breadcrumb-item">
        <%= link_to internal_users_path, class: "text-decoration-none" do %>
          <i class="bi bi-people me-1"></i>Member Management
        <% end %>
      </li>
      <li class="breadcrumb-item">
        <%= link_to internal_user_path(@user), class: "text-decoration-none" do %>
          <%= truncate(@user.full_name, length: 20) %>
        <% end %>
      </li>
    <% else %>
      <li class="breadcrumb-item">
        <%= link_to internal_user_path(@user), class: "text-decoration-none" do %>
          <i class="bi bi-person me-1"></i>My Profile
        <% end %>
      </li>
    <% end %>
    <li class="breadcrumb-item active" aria-current="page">Attendance History</li>
  </ol>
</nav>

<!-- Main Content -->
<div class="row">
  <div class="col-lg-8">
    <!-- Page Header Card -->
    <div class="card shadow-sm border-0 mb-4">
      <div class="card-header bg-primary text-white border-0 py-4">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h1 class="h2 mb-2 text-white">
              <i class="bi bi-clock-history me-2"></i>Attendance History
            </h1>
            <p class="mb-0 text-white-50">
              <i class="bi bi-person-circle me-2"></i>
              <%= @user.full_name %>
              <% if @user == current_user %>
                <span class="badge bg-light text-primary ms-2">You</span>
              <% end %>
            </p>
          </div>
          <div class="text-end">
            <div class="display-4 text-white">
              <i class="bi bi-calendar-check"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tabbed Content -->
    <div class="card shadow-sm border-0">
      <div class="card-header bg-light border-0">
        <ul class="nav nav-tabs card-header-tabs" id="attendanceHistoryTabs" role="tablist">
          <li class="nav-item" role="presentation">
            <button class="nav-link active" id="summary-tab" data-bs-toggle="tab" data-bs-target="#summary" type="button" role="tab" aria-controls="summary" aria-selected="true">
              <i class="bi bi-bar-chart-fill me-2"></i>Summary
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="history-tab" data-bs-toggle="tab" data-bs-target="#history" type="button" role="tab" aria-controls="history" aria-selected="false">
              <i class="bi bi-calendar-event me-2"></i>Attendance Records
              <span class="badge bg-primary ms-1"><%= @attendance_stats[:total] %></span>
            </button>
          </li>
          <% if @user.received_demerits.any? %>
            <li class="nav-item" role="presentation">
              <button class="nav-link" id="demerits-tab" data-bs-toggle="tab" data-bs-target="#demerits" type="button" role="tab" aria-controls="demerits" aria-selected="false">
                <i class="bi bi-exclamation-triangle me-2"></i>Discipline Points
                <span class="badge bg-danger ms-1"><%= @attendance_stats[:demerits] %></span>
              </button>
            </li>
          <% end %>
        </ul>
      </div>

      <div class="card-body">
        <div class="tab-content" id="attendanceHistoryTabContent">
          <!-- Summary Tab -->
          <div class="tab-pane fade show active" id="summary" role="tabpanel" aria-labelledby="summary-tab">
            <!-- Statistics Cards -->
            <div class="row g-3 mb-4">
              <div class="col-lg col-md-4 col-sm-6">
                <div class="card bg-success bg-opacity-10 border-0 text-center h-100">
                  <div class="card-body p-3">
                    <div class="display-6 text-success mb-2">
                      <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <h3 class="text-success mb-1"><%= @attendance_stats[:present] %></h3>
                    <small class="text-muted">Present</small>
                  </div>
                </div>
              </div>
              <div class="col-lg col-md-4 col-sm-6">
                <div class="card bg-danger bg-opacity-10 border-0 text-center h-100">
                  <div class="card-body p-3">
                    <div class="display-6 text-danger mb-2">
                      <i class="bi bi-x-circle-fill"></i>
                    </div>
                    <h3 class="text-danger mb-1"><%= @attendance_stats[:absent] %></h3>
                    <small class="text-muted">Absent</small>
                  </div>
                </div>
              </div>
              <div class="col-lg col-md-4 col-sm-6">
                <div class="card bg-info bg-opacity-10 border-0 text-center h-100">
                  <div class="card-body p-3">
                    <div class="display-6 text-info mb-2">
                      <i class="bi bi-clock-fill"></i>
                    </div>
                    <h3 class="text-info mb-1"><%= @attendance_stats[:tardy] %></h3>
                    <small class="text-muted">Tardy</small>
                  </div>
                </div>
              </div>
              <div class="col-lg col-md-4 col-sm-6">
                <div class="card bg-warning bg-opacity-10 border-0 text-center h-100">
                  <div class="card-body p-3">
                    <div class="display-6 text-warning mb-2">
                      <i class="bi bi-file-earmark-check-fill"></i>
                    </div>
                    <h3 class="text-warning mb-1"><%= @attendance_stats[:excused] %></h3>
                    <small class="text-muted">Excused</small>
                  </div>
                </div>
              </div>
              <div class="col-lg col-md-4 col-sm-6">
                <% if @user.received_demerits.any? %>
                  <a href="#demerits" data-bs-toggle="tab" data-bs-target="#demerits" role="tab" class="text-decoration-none discipline-card-link">
                    <div class="card bg-purple bg-opacity-10 border-0 text-center h-100 clickable-card">
                      <div class="card-body p-3">
                        <div class="display-6 text-purple mb-2">
                          <i class="bi bi-exclamation-triangle-fill"></i>
                        </div>
                        <h3 class="text-purple mb-1"><%= @attendance_stats[:demerits] %></h3>
                        <small class="text-muted">Discipline</small>
                      </div>
                    </div>
                  </a>
                <% else %>
                  <div class="card bg-purple border-0 text-center h-100">
                    <div class="card-body p-3">
                      <div class="display-6 text-purple mb-2">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                      </div>
                      <h3 class="text-purple mb-1"><%= @attendance_stats[:demerits] %></h3>
                      <small class="text-muted">Discipline</small>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>

            <!-- Attendance Rate -->
            <div class="card bg-light border-0 mb-4">
              <div class="card-body">
                <div class="row align-items-center">
                  <div class="col-md-4 text-center">
                    <div class="position-relative d-inline-block">
                      <canvas id="attendanceChart" width="150" height="150"></canvas>
                      <div class="position-absolute top-50 start-50 translate-middle text-center">
                        <div class="h2 text-primary mb-0"><%= @attendance_stats[:present_percentage] %>%</div>
                        <small class="text-muted">Attendance</small>
                      </div>
                    </div>
                  </div>
                  <div class="col-md-8">
                    <h5 class="mb-3">
                      <i class="bi bi-graph-up text-primary me-2"></i>Attendance Performance
                    </h5>
                    <div class="mb-2">
                      <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Total Events Recorded</span>
                        <strong><%= @attendance_stats[:total] %></strong>
                      </div>
                      <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: 100%"></div>
                      </div>
                    </div>
                    <div class="mb-2">
                      <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Effective Present (includes Tardy)</span>
                        <strong><%= @attendance_stats[:present] + @attendance_stats[:tardy] %> / <%= @attendance_stats[:total] %></strong>
                      </div>
                      <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-success" role="progressbar" 
                             style="width: <%= @attendance_stats[:present_percentage] %>%"></div>
                      </div>
                    </div>
                    <small class="text-muted">
                      <i class="bi bi-info-circle me-1"></i>
                      Attendance rate includes both Present and Tardy statuses
                    </small>
                  </div>
                </div>
              </div>
            </div>

            <!-- Absence Points Alert -->
            <div class="alert <%= @user.total_absence_points >= 3 ? 'alert-danger' : (@user.total_absence_points >= 2 ? 'alert-warning' : 'alert-info') %> border-start border-4">
              <div class="d-flex">
                <div class="me-3">
                  <i class="bi bi-<%= @user.total_absence_points >= 3 ? 'exclamation-triangle-fill' : 'calculator' %> display-6"></i>
                </div>
                <div class="flex-grow-1">
                  <h5 class="alert-heading mb-3">
                    Total Absence Points: <strong><%= format_absence_points(@user.total_absence_points) %></strong>
                  </h5>
                  <div class="mb-2">
                    <strong>Breakdown:</strong>
                  </div>
                  <ul class="mb-2">
                    <li>
                      <strong>Absences:</strong> <%= @attendance_stats[:absent] %> events × 1.0 pt = 
                      <strong><%= format_absence_points(@attendance_stats[:absent]) %> pts</strong>
                    </li>
                    <li>
                      <strong>Tardies:</strong> <%= @attendance_stats[:tardy] %> events × 0.33 pt = 
                      <strong><%= format_absence_points((@attendance_stats[:tardy] || 0) * 0.33) %> pts</strong>
                    </li>
                    <li>
                      <strong>Discipline Points:</strong> <%= @attendance_stats[:demerits] %> records = 
                      <strong><%= @attendance_stats[:demerit_points] %> pts</strong>
                    </li>
                  </ul>
                  <% if @user.total_absence_points >= 3 %>
                    <div class="alert alert-danger mb-0">
                      <i class="bi bi-exclamation-triangle-fill me-2"></i>
                      <strong>Warning:</strong> More than 3 absence points per semester may result in grade penalties
                    </div>
                  <% elsif @user.total_absence_points >= 2 %>
                    <div class="alert alert-warning mb-0">
                      <i class="bi bi-info-circle-fill me-2"></i>
                      You're approaching the 3-point threshold. Please maintain good attendance.
                    </div>
                  <% else %>
                    <small class="text-muted">
                      <i class="bi bi-check-circle me-1"></i>
                      You're in good standing. Keep up the great attendance!
                    </small>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <!-- Attendance History Tab -->
          <div class="tab-pane fade" id="history" role="tabpanel" aria-labelledby="history-tab">
            <% if @attendances.empty? %>
              <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                No attendance records found.
              </div>
            <% else %>
              <div class="table-responsive">
                <table class="table table-hover align-middle">
                  <thead class="table-light">
                    <tr>
                      <th scope="col">
                        <i class="bi bi-calendar-event me-1" aria-hidden="true"></i>Event
                      </th>
                      <th scope="col">
                        <i class="bi bi-calendar3 me-1" aria-hidden="true"></i>Date
                      </th>
                      <th scope="col">
                        <i class="bi bi-geo-alt me-1" aria-hidden="true"></i>Location
                      </th>
                      <th scope="col">
                        <i class="bi bi-check-circle me-1" aria-hidden="true"></i>Status
                      </th>
                      <th scope="col">
                        <i class="bi bi-sticky me-1" aria-hidden="true"></i>Note
                      </th>
                    </tr>
                  </thead>
                  <tbody>
                    <% @attendances.each do |attendance| %>
                      <tr>
                        <td>
                          <%= link_to attendance.event.title, internal_event_path(attendance.event), 
                              class: "text-decoration-none fw-medium" %>
                        </td>
                        <td class="text-muted">
                          <%= attendance.event.date.strftime("%b %d, %Y") %>
                          <br>
                          <small><%= attendance.event.date.strftime("%I:%M %p") %></small>
                        </td>
                        <td class="text-muted"><%= attendance.event.location %></td>
                        <td>
                          <% case attendance.status %>
                          <% when 'present' %>
                            <span class="badge bg-success px-3">
                              <i class="bi bi-check-circle me-1"></i>Present
                            </span>
                          <% when 'excused' %>
                            <span class="badge bg-warning px-3">
                              <i class="bi bi-file-earmark-check me-1"></i>Excused
                            </span>
                          <% when 'absent' %>
                            <span class="badge bg-danger px-3">
                              <i class="bi bi-x-circle me-1"></i>Absent
                            </span>
                          <% when 'tardy' %>
                            <span class="badge bg-info px-3">
                              <i class="bi bi-clock me-1"></i>Tardy
                            </span>
                          <% end %>
                        </td>
                        <td>
                          <% if attendance.note.present? %>
                            <span class="text-muted">
                              <i class="bi bi-chat-left-text me-1"></i>
                              <%= truncate(attendance.note, length: 30) %>
                            </span>
                          <% else %>
                            <span class="text-muted fst-italic">—</span>
                          <% end %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% end %>
          </div>

          <!-- Discipline Points Tab -->
          <% if @user.received_demerits.any? %>
            <div class="tab-pane fade" id="demerits" role="tabpanel" aria-labelledby="demerits-tab">
              <div class="alert alert-warning border-warning border-start border-4 mb-4">
                <div class="d-flex align-items-center">
                  <i class="bi bi-exclamation-triangle-fill display-6 me-3"></i>
                  <div>
                    <h5 class="alert-heading mb-1">Discipline Points Summary</h5>
                    <p class="mb-0">
                      You have <strong><%= @attendance_stats[:demerits] %></strong> discipline point record(s) 
                      totaling <strong><%= @attendance_stats[:demerit_points] %></strong> absence points.
                    </p>
                  </div>
                </div>
              </div>

              <div class="table-responsive">
                <table class="table table-hover align-middle">
                  <thead class="table-light">
                    <tr>
                      <th scope="col">
                        <i class="bi bi-calendar3 me-1" aria-hidden="true"></i>Date &amp; Time
                      </th>
                      <th scope="col">
                        <i class="bi bi-hash me-1" aria-hidden="true"></i>Value
                      </th>
                      <th scope="col">
                        <i class="bi bi-chat-square-text me-1" aria-hidden="true"></i>Reason
                      </th>
                      <th scope="col">
                        <i class="bi bi-person me-1" aria-hidden="true"></i>Given By
                      </th>
                      <th scope="col">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% @user.received_demerits.order(date: :desc).each do |demerit| %>
                      <tr>
                        <td class="text-muted">
                          <%= demerit.date.strftime("%b %d, %Y") %>
                          <br>
                          <small><%= demerit.date.strftime("%I:%M %p") %></small>
                        </td>
                        <td>
                          <span class="badge bg-danger fs-6"><%= demerit.value %></span>
                          <div>
                            <small class="text-muted">
                              (<%= format_absence_points(demerit.absence_points) %> pts)
                            </small>
                          </div>
                        </td>
                        <td>
                          <span class="fw-medium"><%= truncate(demerit.reason, length: 50) %></span>
                        </td>
                        <td class="text-muted">
                          <i class="bi bi-person-circle me-1"></i>
                          <%= demerit.given_by.full_name %>
                        </td>
                        <td>
                          <%= link_to internal_demerit_path(demerit), class: "btn btn-sm btn-outline-primary" do %>
                            <i class="bi bi-eye me-1"></i>View Details
                          <% end %>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                  <tfoot class="table-light">
                    <tr>
                      <td colspan="2">
                        <strong>
                          <i class="bi bi-calculator me-2"></i>Total Discipline Records: 
                          <%= @user.received_demerits.count %>
                        </strong>
                      </td>
                      <td colspan="3" class="text-end">
                        <strong>Total Absence Points from Discipline: 
                          <%= @attendance_stats[:demerit_points] %>
                        </strong>
                      </td>
                    </tr>
                  </tfoot>
                </table>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="col-lg-4">
    <!-- Quick Stats Card -->
    <div class="card shadow-sm border-0 mb-4">
      <div class="card-header bg-light border-0">
        <h5 class="card-title mb-0">
          <i class="bi bi-speedometer2 text-primary me-2"></i>Quick Stats
        </h5>
      </div>
      <div class="card-body">
        <ul class="list-unstyled mb-0">
          <li class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
            <span>
              <i class="bi bi-calendar-event text-primary me-2"></i>
              <strong>Total Events</strong>
            </span>
            <span class="badge bg-primary fs-6"><%= @attendance_stats[:total] %></span>
          </li>
          <li class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
            <span>
              <i class="bi bi-check-circle text-success me-2"></i>
              <strong>Attendance Rate</strong>
            </span>
            <span class="badge bg-success fs-6"><%= @attendance_stats[:present_percentage] %>%</span>
          </li>
          <li class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
            <span>
              <i class="bi bi-calculator text-info me-2"></i>
              <strong>Absence Points</strong>
            </span>
            <span class="badge bg-<%= @user.total_absence_points >= 3 ? 'danger' : (@user.total_absence_points >= 2 ? 'warning' : 'info') %> fs-6">
              <%= format_absence_points(@user.total_absence_points) %>
            </span>
          </li>
          <% if @user.received_demerits.any? %>
            <li class="d-flex justify-content-between align-items-center">
              <span>
                <i class="bi bi-exclamation-triangle text-warning me-2"></i>
                <strong>Active Discipline Points</strong>
              </span>
              <span class="badge bg-warning fs-6"><%= @attendance_stats[:demerits] %></span>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <!-- Navigation Card -->
    <div class="card shadow-sm border-0">
      <div class="card-header bg-light border-0">
        <h5 class="card-title mb-0">
          <i class="bi bi-list text-primary me-2"></i>Navigation
        </h5>
      </div>
      <div class="card-body d-grid gap-2">
        <%= link_to internal_user_path(@user), class: "btn btn-outline-primary" do %>
          <i class="bi bi-person me-2"></i>Back to Profile
        <% end %>
        
        <%= link_to internal_events_path, class: "btn btn-outline-success" do %>
          <i class="bi bi-calendar-event me-2"></i>View Events
        <% end %>
        
        <%= link_to internal_excuses_path, class: "btn btn-outline-warning" do %>
          <i class="bi bi-file-earmark-text me-2"></i>Excuses
        <% end %>

        <% if current_user == @user && @user.received_demerits.any? %>
          <%= link_to internal_my_demerits_path, class: "btn btn-outline-danger" do %>
            <i class="bi bi-exclamation-triangle me-2"></i>My Discipline Points
          <% end %>
        <% end %>

        <% if current_user.admin? %>
          <hr class="my-2">
          <%= link_to internal_users_path, class: "btn btn-outline-secondary" do %>
            <i class="bi bi-people me-2"></i>All Members
          <% end %>
          
          <%= link_to absence_report_internal_users_path, class: "btn btn-outline-danger" do %>
            <i class="bi bi-calendar-x me-2"></i>Absence Report
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Custom Styles -->
<style>
  .card {
    transition: transform 0.2s ease-in-out;
    position: relative;
    z-index: 1;
  }
  
  .card:hover {
    transform: translateY(-1px);
    z-index: 10;
  }
  
  .bg-opacity-10 {
    --bs-bg-opacity: 0.1;
  }

  /* Purple color for discipline points */
  .text-purple {
    color: #6f42c1;
  }

  .bg-purple {
    background-color: rgba(111, 66, 193, 0.1);
  }

  /* Clickable discipline card */
  .discipline-card-link {
    display: block;
    height: 100%;
  }

  .discipline-card-link .clickable-card {
    cursor: pointer;
    transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
  }

  .discipline-card-link:hover .clickable-card {
    transform: translateY(-3px);
    box-shadow: 0 4px 12px rgba(111, 66, 193, 0.3);
  }

  .nav-tabs .nav-link {
    color: #6c757d;
    border: none;
    padding: 0.75rem 1.25rem;
  }

  .nav-tabs .nav-link:hover {
    border: none;
    color: #0d6efd;
  }

  .nav-tabs .nav-link.active {
    color: #0d6efd;
    background-color: transparent;
    border: none;
    border-bottom: 3px solid #0d6efd;
    font-weight: 600;
  }

  .table > :not(caption) > * > * {
    padding: 1rem 0.75rem;
  }

  .badge {
    font-weight: 500;
  }

  /* Mobile-Friendly Styles */
  @media (max-width: 768px) {
    /* Compact header for mobile */
    .card-header.bg-primary .display-4 {
      font-size: 2rem !important;
    }

    .card-header.bg-primary h1 {
      font-size: 1.5rem !important;
    }

    .card-header.bg-primary p {
      font-size: 0.9rem !important;
    }

    /* Horizontal scrollable tabs with better touch targets */
    .nav-tabs {
      flex-wrap: nowrap;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: thin;
      border-bottom: 1px solid #dee2e6;
    }

    .nav-tabs::-webkit-scrollbar {
      height: 4px;
    }

    .nav-tabs::-webkit-scrollbar-track {
      background: #f1f1f1;
    }

    .nav-tabs::-webkit-scrollbar-thumb {
      background: #888;
      border-radius: 2px;
    }

    .nav-tabs .nav-item {
      flex-shrink: 0;
    }

    .nav-tabs .nav-link {
      white-space: nowrap;
      padding: 1rem 1rem;
      min-height: 48px;
      display: flex;
      align-items: center;
    }

    /* Stack statistics cards in single column */
    .row.g-3.mb-4 > div[class*="col-"] {
      width: 100%;
      margin-bottom: 0.75rem;
    }

    /* Adjust chart container for mobile */
    .col-md-4.text-center {
      margin-bottom: 1.5rem;
    }

    #attendanceChart {
      width: 120px !important;
      height: 120px !important;
    }

    /* Make tables horizontally scrollable */
    .table-responsive {
      border: 1px solid #dee2e6;
      border-radius: 0.375rem;
      margin-bottom: 1rem;
    }

    .table {
      margin-bottom: 0;
      font-size: 0.875rem;
    }

    .table th,
    .table td {
      padding: 0.75rem 0.5rem !important;
      white-space: nowrap;
    }

    /* Adjust badge sizes for readability */
    .badge {
      font-size: 0.75rem !important;
