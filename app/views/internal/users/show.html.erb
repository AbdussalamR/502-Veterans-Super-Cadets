<!-- Breadcrumb Navigation -->
<nav aria-label="breadcrumb" class="mb-4">
  <ol class="breadcrumb">
    <% if current_user.admin? %>
      <li class="breadcrumb-item">
        <%= link_to internal_users_path, class: "text-decoration-none" do %>
          <i class="bi bi-people me-1"></i>Member Management
        <% end %>
      </li>
    <% else %>
      <li class="breadcrumb-item">
        <%= link_to internal_events_path, class: "text-decoration-none" do %>
          <i class="bi bi-house me-1"></i>Dashboard
        <% end %>
      </li>
    <% end %>
    <li class="breadcrumb-item active" aria-current="page">
      <%= truncate(@user.full_name, length: 30) %>
    </li>
  </ol>
</nav>

<!-- User Profile Header -->
<div class="row">
  <div class="col-lg-8">
    <!-- Main Profile Card -->
    <div class="card shadow-sm border-0 mb-4">
      <!-- Profile Header -->
      <div class="card-header <%= 
        case @user.role
        when 'super_admin' then 'bg-danger text-white'
        when 'officer' then 'bg-warning text-dark'
        else 'bg-primary text-white'
        end
      %> border-0 py-4">
        <div class="d-flex justify-content-between align-items-start">
          <div class="d-flex align-items-center">
            <div class="me-4">
              <% if @user.avatar_url.present? %>
                <img src="<%= @user.avatar_url %>" alt="<%= @user.full_name %>" 
                     class="rounded-circle border border-white border-3" 
                     style="width: 100px; height: 100px; object-fit: cover;">
              <% else %>
                <div class="rounded-circle bg-white bg-opacity-20 d-flex align-items-center justify-content-center border border-white border-3" 
                     style="width: 100px; height: 100px;">
                  <i class="bi bi-person display-2 <%= 
                    @user.role == 'officer' ? 'text-dark' : 'text-white' 
                  %>"></i>
                </div>
              <% end %>
            </div>
            <div>
              <h1 class="h2 mb-2 <%= @user.role == 'officer' ? 'text-dark' : 'text-white' %>">
                <%= @user.full_name %>
                <% if @user == current_user %>
                  <span class="badge bg-light text-dark ms-2">
                    <i class="bi bi-person-check me-1"></i>You
                  </span>
                <% end %>
              </h1>
              <div class="d-flex flex-wrap gap-2 align-items-center">
                <span class="badge <%= 
                  case @user.role
                  when 'super_admin' then 'bg-white text-danger'
                  when 'officer' then 'bg-dark text-white'
                  else 'bg-white text-primary'
                  end
                %> px-3 py-2">
                  <i class="bi bi-<%= 
                    case @user.role
                    when 'super_admin' then 'shield-fill-exclamation'
                    when 'officer' then 'award'
                    else 'person'
                    end
                  %> me-2"></i>
                  <%= @user.role_display_name %>
                </span>
                <% if @user.approval_status == 'approved' %>
                  <span class="badge bg-success bg-opacity-20 text-white px-2">
                    <i class="bi bi-check-circle me-1"></i>Verified Member
                  </span>
                <% end %>
              </div>
              <div class="mt-2">
                <small class="<%= @user.role == 'officer' ? 'text-dark' : 'text-white' %> opacity-75">
                  <i class="bi bi-calendar3 me-1"></i>
                  Member since <%= @user.created_at.strftime('%B %Y') %>
                </small>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Information -->
      <div class="card-body p-4">
        <h5 class="text-dark mb-3">
          <i class="bi bi-person-lines-fill text-primary me-2"></i>Contact Information
        </h5>
        
        <div class="row">
          <div class="col-md-6">
            <div class="d-flex align-items-center mb-3">
              <div class="me-3 text-primary">
                <i class="bi bi-envelope-fill"></i>
              </div>
              <div>
                <strong class="d-block text-dark">Email Address</strong>
                <span class="text-muted"><%= @user.email %></span>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="d-flex align-items-center mb-3">
              <div class="me-3 text-primary">
                <i class="bi bi-person-badge-fill"></i>
              </div>
              <div>
                <strong class="d-block text-dark">Member ID</strong>
                <span class="text-muted">#<%= @user.id %></span>
              </div>
            </div>
          </div>
        </div>

        <% if @user == current_user %>
          <div class="mt-2">
            <%= link_to "https://forms.gle/L9n863sALjhJi6hp6", 
                class: "btn btn-outline-primary",
                target: "_blank",
                title: "Fill out additional member information" do %>
              <i class="bi bi-file-earmark-text me-1"></i>Additional Information Form
            <% end %>
          </div>
        <% end %>

        <!-- Activity Statistics -->
        <h5 class="text-dark mb-3 mt-4">
          <i class="bi bi-bar-chart-fill text-primary me-2"></i>Activity Statistics
        </h5>
        
        <div class="row">
          <div class="col-md-4">
            <div class="card bg-info bg-opacity-10 border-0 text-center">
              <div class="card-body p-3">
                <div class="display-6 text-info mb-2">
                  <i class="bi bi-calendar-event"></i>
                </div>
                <h4 class="text-info mb-1"><%= @total_events %></h4>
                <small class="text-muted">Events Attended</small>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card bg-success bg-opacity-10 border-0 text-center">
              <div class="card-body p-3">
                <div class="display-6 text-success mb-2">
                  <i class="bi bi-person-check"></i>
                </div>
                <h4 class="text-success mb-1">
                  <%= @total_present %>
                </h4>
                <small class="text-muted">Present Count</small>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card bg-danger bg-opacity-10 border-0 text-center">
              <div class="card-body p-3">
                <div class="display-6 text-danger mb-2">
                  <i class="bi bi-exclamation-triangle"></i>
                </div>
                <h4 class="text-danger mb-1"><%= @total_tardies_and_demerits %></h4>
                <small class="text-muted">Total Tardies & Discipline Points</small>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Total Absence Points -->
        <div class="alert <%= @user.total_absence_points >= 3 ? 'alert-danger' : (@user.total_absence_points >= 2 ? 'alert-warning' : 'alert-info') %> mt-3">
          <h5 class="alert-heading">
            <i class="bi bi-calendar-x me-2"></i>
            Total Absence Points: <strong><%= format_absence_points(@user.total_absence_points) %></strong>
          </h5>
          <p class="mb-0">
            Includes regular absences (1 point each), tardies (0.33 points each), and discipline points.
            <% if @user.total_absence_points >= 3 %>
              <span class="text-danger fw-bold">Warning: More than 3 absence points per semester may result in grade penalties</span>
            <% end %>
          </p>
        </div>
        
        <div class="row">
        </div>

        <!-- Quick Actions -->
        <div class="d-flex flex-wrap gap-2 mt-4">
          <%= link_to attendance_history_internal_user_path(@user), class: "btn btn-outline-info" do %>
            <i class="bi bi-clock-history me-2"></i>View Attendance History
          <% end %>
          <% if @user.received_demerits.any? %>
            <% if current_user == @user %>
              <%= link_to internal_my_demerits_path, class: "btn btn-outline-warning" do %>
                <i class="bi bi-exclamation-triangle me-2"></i>View My Discipline Points (<%= @user.received_demerits.count %>)
              <% end %>
            <% elsif current_user.admin? || current_user.officer? %>
              <button type="button" class="btn btn-outline-warning" data-bs-toggle="collapse" data-bs-target="#demerits-section">
                <i class="bi bi-exclamation-triangle me-2"></i>View Discipline Points (<%= @user.received_demerits.count %>)
              </button>
            <% end %>
          <% end %>
          <% if (current_user.admin? || current_user.officer?) && @user != current_user %>
            <%= link_to new_internal_user_demerit_path(@user), class: "btn btn-danger" do %>
              <i class="bi bi-clipboard-x me-2"></i>Give Discipline Points
            <% end %>
          <% end %>
        </div>

        <!-- Discipline Points History -->
        <% if @user.received_demerits.any? %>
          <div id="demerits-section" class="collapse mt-4">
            <div class="card border-warning border-start border-4 mb-4">
              <div class="card-header bg-warning bg-opacity-10">
                <h5 class="mb-0 text-warning">
                  <i class="bi bi-exclamation-triangle me-2"></i>Discipline Points History
                </h5>
              </div>
              <div class="card-body p-0">
                <div class="table-responsive">
                  <table class="table table-hover mb-0">
                    <thead class="table-light">
                      <tr>
                        <th>Date</th>
                        <th>Value</th>
                        <th>Reason</th>
                        <th>Given By</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% @user.received_demerits.order(date: :desc).each do |demerit| %>
                        <tr>
                          <td><%= demerit.date.strftime("%b %d, %Y") %></td>
                          <td>
                            <span class="badge bg-danger"><%= demerit.value %></span>
                            <small class="text-muted">(<%= format_absence_points(demerit.absence_points) %> pts)</small>
                          </td>
                          <td><%= truncate(demerit.reason, length: 40) %></td>
                          <td><%= demerit.given_by.full_name %></td>
                          <td>
                            <div class="btn-group btn-group-sm">
                              <%= link_to internal_demerit_path(demerit), class: "btn btn-outline-secondary" do %>
                                <i class="bi bi-eye"></i>
                              <% end %>
                              <% if current_user.admin? %>
                                <%= link_to edit_internal_demerit_path(demerit), class: "btn btn-outline-warning" do %>
                                  <i class="bi bi-pencil"></i>
                                <% end %>
                                <%= button_to internal_demerit_path(demerit, source: 'user_profile'), method: :delete,
                                    form: { style: 'display: inline-block;' },
                                    data: { turbo_confirm: "Are you sure you want to delete this discipline point record?" },
                                    class: "btn btn-outline-danger" do %>
                                  <i class="bi bi-trash"></i>
                                <% end %>
                              <% end %>
                            </div>
                          </td>
                        </tr>
                      <% end %>
                      <!-- Summary row -->
                      <tr class="table-light">
                        <td colspan="1"><strong>Total Discipline Records:</strong> <%= @user.received_demerits.count %></td>
                        <td colspan="4" class="text-end"><strong>Total Absence Points:</strong> <%= format_absence_points(@user.total_absence_points) %></td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="col-lg-4">
    <!-- Admin/Officer Actions -->
    <% if (current_user.admin? || current_user.officer?) && @user != current_user %>
      <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-light border-0">
          <h5 class="card-title mb-0">
            <i class="bi bi-gear text-primary me-2"></i><%= current_user.admin? ? 'Director Actions' : 'Officer Actions' %>
          </h5>
        </div>
        <div class="card-body d-grid gap-2">
          <% if current_user.admin? %>
            <%= link_to edit_internal_user_path(@user), class: "btn btn-outline-warning" do %>
              <i class="bi bi-pencil me-2"></i>Edit Member Info
            <% end %>
          <% end %>
          
          <%= link_to new_internal_user_demerit_path(@user), class: "btn btn-danger" do %>
            <i class="bi bi-clipboard-x me-2"></i>Give Discipline Points
          <% end %>
          
          <% if current_user.super_admin? %>
            <!-- Role Management -->
            <div class="dropdown-center">
              <button class="btn btn-outline-success dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
                <i class="bi bi-person-gear me-2"></i>Manage Role
              </button>
              <ul class="dropdown-menu w-100">
                <% case @user.role %>
                <% when 'user' %>
                  <li>
                    <%= button_to promote_to_officer_internal_user_path(@user), method: :patch,
                        data: { confirm: "Are you sure you want to promote #{@user.full_name} to officer?" },
                        class: "dropdown-item border-0 bg-transparent w-100 text-start" do %>
                      <i class="bi bi-arrow-up-circle me-2 text-success"></i>Promote to Officer
                    <% end %>
                  </li>
                  <li>
                    <%= button_to promote_to_super_admin_internal_user_path(@user), method: :patch,
                        data: { confirm: "Are you sure you want to promote #{@user.full_name} to director?" },
                        class: "dropdown-item border-0 bg-transparent w-100 text-start text-danger" do %>
                      <i class="bi bi-shield-exclamation me-2"></i>Promote to Director
                    <% end %>
                  </li>
                <% when 'officer' %>
                  <li>
                    <%= button_to promote_to_super_admin_internal_user_path(@user), method: :patch,
                        data: { confirm: "Are you sure you want to promote #{@user.full_name} to director?" },
                        class: "dropdown-item border-0 bg-transparent w-100 text-start text-danger" do %>
                      <i class="bi bi-shield-exclamation me-2"></i>Promote to Director
                    <% end %>
                  </li>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                    <%= button_to demote_to_user_internal_user_path(@user), method: :patch,
                        data: { confirm: "Are you sure you want to demote #{@user.full_name} to member?" },
                        class: "dropdown-item border-0 bg-transparent w-100 text-start text-warning" do %>
                      <i class="bi bi-arrow-down-circle me-2"></i>Demote to Member
                    <% end %>
                  </li>
                <% when 'super_admin' %>
                  <li>
                    <%= button_to demote_to_officer_internal_user_path(@user), method: :patch,
                        data: { confirm: "Are you sure you want to demote #{@user.full_name} to officer?" },
                        class: "dropdown-item border-0 bg-transparent w-100 text-start text-warning" do %>
                      <i class="bi bi-arrow-down-circle me-2"></i>Demote to Officer
                    <% end %>
                  </li>
                  <li>
                    <%= button_to demote_to_user_internal_user_path(@user), method: :patch,
                        data: { confirm: "Are you sure you want demote #{@user.full_name} to member?" },
                        class: "dropdown-item border-0 bg-transparent w-100 text-start text-warning" do %>
                      <i class="bi bi-arrow-down-circle me-2"></i>Demote to Member
                    <% end %>
                  </li>
                <% end %>
              </ul>
            </div>
            
            <!-- Delete User -->
            <%= button_to internal_user_path(@user), method: :delete,
                data: { confirm: "Are you sure you want to PERMANENTLY DELETE #{@user.full_name}? This action cannot be undone and will remove all their data including attendance records." },
                class: "btn btn-outline-danger w-100 mt-2" do %>
              <i class="bi bi-trash me-2"></i>Delete User
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Navigation -->
    <div class="card shadow-sm border-0">
      <div class="card-header bg-light border-0">
        <h5 class="card-title mb-0">
          <i class="bi bi-list text-primary me-2"></i>Navigation
        </h5>
      </div>
      <div class="card-body d-grid gap-2">
      
      <%= link_to internal_events_path, class: "btn btn-outline-success" do %>
        <i class="bi bi-calendar-event me-2"></i>Events
        <% end %>
        
        <%= link_to internal_excuses_path, class: "btn btn-outline-warning" do %>
          <i class="bi bi-file-earmark-text me-2"></i>Excuses
        <% end %>

        <% if current_user.admin? %>
          <%= link_to internal_users_path, class: "btn btn-outline-primary" do %>
            <i class="bi bi-people me-2"></i>All Members
          <% end %>
          <%= link_to absence_report_internal_users_path, class: "btn btn-outline-danger" do %>
            <i class="bi bi-calendar-x me-2"></i>Absence Report
          <% end %>
          <%= link_to internal_demerits_path, class: "btn btn-outline-danger" do %>
            <i class="bi bi-exclamation-triangle me-2"></i>Discipline Points
          <% end %>
          <%= link_to admin_registrations_path, class: "btn btn-outline-danger" do %>
            <i class="bi bi-person-check me-2"></i>Registration Approval
          <% end %>
        <% end %>
          
        <%= link_to internal_events_path, class: "btn btn-outline-secondary" do %>
          <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Custom Styles -->
<style>
  .card {
    transition: transform 0.2s ease-in-out;
    position: relative;
    z-index: 1;
  }
  
  .card:hover {
    transform: translateY(-1px);
    z-index: 10;
  }
  
  .bg-opacity-20 {
    --bs-bg-opacity: 0.2;
  }

  /* Mobile-Friendly Styles for User Profile */
  @media (max-width: 768px) {
    /* Profile header adjustments */
    .card-header.bg-danger,
    .card-header.bg-warning,
    .card-header.bg-primary {
      padding: 1rem !important;
    }

    .card-header .d-flex .me-4 {
      margin-right: 1rem !important;
    }

    .card-header .rounded-circle {
      width: 70px !important;
      height: 70px !important;
    }

    .card-header h1 {
      font-size: 1.5rem !important;
    }

    .card-header .badge {
      font-size: 0.75rem !important;
      padding: 0.35em 0.65em !important;
    }

    /* Contact information grid */
    .row > div.col-md-6 {
      width: 100%;
      margin-bottom: 0.5rem;
    }

    /* Statistics cards - stack vertically */
    .row > div.col-md-4 {
      width: 100%;
      margin-bottom: 0.75rem;
    }

    .card-body .display-6 {
      font-size: 1.75rem !important;
    }

    /* Quick action buttons */
    .d-flex.flex-wrap.gap-2 {
      gap: 0.5rem !important;
    }

    .d-flex.flex-wrap.gap-2 .btn {
      width: 100%;
      min-height: 44px;
      justify-content: center;
      display: flex;
      align-items: center;
    }

    /* Breadcrumb */
    .breadcrumb {
      font-size: 0.875rem;
      padding: 0.5rem 0;
    }

    /* Card body padding */
    .card-body {
      padding: 1rem !important;
    }

    /* Alerts */
    .alert {
      font-size: 0.9rem;
      padding: 0.75rem;
    }

    /* Table responsive */
    .table-responsive {
      font-size: 0.875rem;
    }

    .table th,
    .table td {
      padding: 0.5rem !important;
    }

    .btn-group-sm .btn {
      padding: 0.25rem 0.4rem;
      font-size: 0.8rem;
    }

    /* Sidebar moves below on mobile */
    .col-lg-4 {
      margin-top: 1rem;
    }

    /* Sidebar buttons */
    .col-lg-4 .d-grid .btn {
      min-height: 44px;
    }

    /* Dropdown in sidebar */
    .dropdown-menu {
      font-size: 0.9rem;
    }

    .dropdown-item {
      padding: 0.75rem 1rem !important;
      min-height: 44px;
      display: flex;
      align-items: center;
    }
  }

  /* Small phones - extra compact */
  @media (max-width: 375px) {
    .card-header h1 {
      font-size: 1.25rem !important;
    }

    .card-header .rounded-circle {
      width: 60px !important;
      height: 60px !important;
    }

    .btn {
      font-size: 0.875rem;
      padding: 0.5rem 0.75rem;
    }

    .display-6 {
      font-size: 1.5rem !important;
    }
  }

  /* Landscape orientation on mobile */
  @media (max-width: 768px) and (orientation: landscape) {
    .row > div.col-md-4 {
      width: 50%;
      float: left;
    }
  }
</style>
