<div class="col-lg-6 col-xl-4">
  <div class="card h-100 shadow-sm border-0 hover-lift">
    <!-- Event Header -->
    <div class="card-header bg-primary text-white border-0">
      <div class="d-flex justify-content-between align-items-start">
        <h5 class="card-title mb-0 text-truncate">
          <i class="bi bi-calendar-event me-2"></i><%= event.title %>
        </h5>
        <%= attendance_status_badge(current_user, event) %>
      </div>
    </div>
    
    <!-- Event Details -->
    <div class="card-body">
      <div class="mb-3">
        <div class="d-flex align-items-center mb-2">
          <i class="bi bi-calendar3 text-primary me-2"></i>
          <span class="fw-medium">
            <%= event.date.strftime("%A, %B %d, %Y %l:%M %p") %>
            <% if event.end_time.present? %>
              –
              <% if event.end_time.to_date != event.date.to_date %>
                <%= event.end_time.strftime("%A, %B %d, %Y %l:%M %p") %>
              <% else %>
                <%= event.end_time.strftime("%l:%M %p") %>
              <% end %>
            <% end %>
          </span>
        </div>
        <div class="d-flex align-items-center mb-2">
          <i class="bi bi-geo-alt text-primary me-2"></i>
          <span class="text-muted"><%= event.location %></span>
        </div>

        <%# Overlapping events warning %>
        <% overlapping = event.overlapping_events %>
        <% if overlapping.exists? %>
          <div class="alert alert-warning py-2 mt-2 mb-2">
            <i class="bi bi-exclamation-triangle-fill me-1"></i>
            This event conflicts with:
            <ul class="mb-0">
              <% overlapping.each do |e| %>
                <li>
                  <strong><%= e.title %></strong> — 
                  <%= e.date.strftime("%A, %B %d, %Y %l:%M %p") %>
                  <% if e.end_time.present? %>
                    –
                    <% if e.end_time.to_date != e.date.to_date %>
                      <%= e.end_time.strftime("%A, %B %d, %Y %l:%M %p") %>
                    <% else %>
                      <%= e.end_time.strftime("%l:%M %p") %>
                    <% end %>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <% if current_user&.admin? && event.approved_excuses_count > 0 %>
          <div class="d-flex align-items-center mb-2">
            <i class="bi bi-file-earmark-text text-warning me-2"></i>
            <span class="text-warning fw-medium"><%= event.approved_excuses_count %> <%= 'excuse'.pluralize(event.approved_excuses_count) %></span>
          </div>
        <% end %>
        <% if event.description.present? %>
          <div class="d-flex align-items-start mt-3">
            <i class="bi bi-info-circle text-primary me-2 mt-1"></i>
            <p class="text-muted mb-0 small">
              <%= truncate(event.description, length: 100) %>
            </p>
          </div>
        <% end %>
      </div>
    </div>
    
    <!-- Action Buttons -->
    <div class="card-footer bg-light border-0">
      <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center">
        <%= link_to internal_event_path(event), class: "btn btn-outline-primary btn-sm flex-fill" do %>
          <i class="bi bi-eye me-1"></i>View Details
        <% end %>
        
        <div class="dropdown">
          <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
            <i class="bi bi-three-dots"></i>
          </button>
          <ul class="dropdown-menu dropdown-menu-end">
            <li>
              <%= link_to internal_event_path(event), class: "dropdown-item" do %>
                <i class="bi bi-eye me-2"></i>View Details
              <% end %>
            </li>
            <% if current_user&.admin? %>
              <li>
                <%= link_to edit_internal_event_path(event), class: "dropdown-item" do %>
                  <i class="bi bi-pencil me-2"></i>Edit Event
                <% end %>
              </li>
              <li>
                <%= link_to new_internal_event_attendance_path(event), class: "dropdown-item" do %>
                  <i class="bi bi-people me-2"></i>Take Attendance
                <% end %>
              </li>
              <li><hr class="dropdown-divider"></li>
              <li>
                  <%= button_to internal_event_path(event), method: :delete,
                    form: { data: { turbo_confirm: "Are you sure you want to delete this event?" } },
                    class: "dropdown-item text-danger border-0 bg-transparent w-100 text-start" do %>
                    <i class="bi bi-trash me-2"></i>Delete Event
                  <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>
