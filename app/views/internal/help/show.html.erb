<div class="help-container">
  <div class="help-header">
    <h1><span aria-hidden="true">🎵</span> Help &amp; Guidance</h1>
    <p>Your complete guide to using the Singing Cadets management system</p>
  </div>

  <% if user_signed_in? %>
    <% if current_user.user? %>
      <!-- MEMBERS SECTION -->
      <section class="help-role-section">
        <div class="role-header">
          <h2><span aria-hidden="true">👤</span> Member Guide</h2>
          <p>Everything you need to know as a member</p>
        </div>
        <p style="text-align: center;">
          <a href="https://docs.google.com/document/d/190jOT3i6MYmqPtzMAK65fhSYLoNE2MGP/edit?usp=sharing&ouid=111553121125115305524&rtpof=true&sd=true">READ THE USER GUIDE HERE!</a>
        </p>
      </section>
    <% end %>

    <% if current_user.officer? || current_user.admin? %>
      <!-- OFFICERS & ADMINS SECTION -->
      <section class="help-role-section">
        <div class="role-header">
          <h2><span aria-hidden="true">👮</span> Officer &amp; Admin Guide</h2>
        </div>
        <p style="text-align: center;">
          <a href="https://docs.google.com/document/d/1pJ0uDXSoorb2kygwkzFR9Fglkocff62x/edit?usp=sharing&ouid=111553121125115305524&rtpof=true&sd=true">READ THE ADMIN GUIDE HERE!</a>
        </p>
      </section>
    <% end %>
  <% end %>

  <!-- TRAINING VIDEOS -->
  <section class="help-role-section">
    <div class="role-header">
      <h2><span aria-hidden="true">🎥</span> Training Videos</h2>
      <p>Learn by watching — click "Watch" to open the video in a new tab</p>
    </div>

    <div class="help-grid">
      <% if user_signed_in? && current_user.user? %>
        <!-- Member Videos (list with Watch button) -->
        <div class="help-card">
          <div class="card-header">
            <h3>Member Videos</h3>
          </div>
          <div class="card-content">
            <ul class="training-list">
              <li class="training-item">
                <div class="training-meta">
                  <strong>Navigating the Website</strong><br>
                  <small>Quick tour of the app and where to find things.</small>
                </div>
                <%= link_to "Watch", "https://drive.google.com/file/d/1OSFrWmGZoiwZF9WRiZ9-L51UhfjSMlX9/view?usp=drive_link", target: "_blank", rel: "noopener", class: "video-btn" %>
              </li>

              <li class="training-item">
                <div class="training-meta">
                  <strong>Excuses</strong><br>
                  <small>How to submit, manage, and delete one-time excuses.</small>
                </div>
                <%= link_to "Watch", "https://drive.google.com/file/d/1Z96sFFqU4518acutYIDmytkzhYGzi-zZ/view?usp=drive_link", target: "_blank", rel: "noopener", class: "video-btn" %>
              </li>

              <li class="training-item">
                <div class="training-meta">
                  <strong>Recurring Excuses</strong><br>
                  <small>How to submit, manage, and delete recurring excuses.</small>
                </div>
                <%= link_to "Watch", "https://drive.google.com/file/d/10hsH0DmpMmicyrC6diEtAY-k5-5MbIie/view?usp=drive_link", target: "_blank", rel: "noopener", class: "video-btn" %>
              </li>

              <li class="training-item">
                <div class="training-meta">
                  <strong>Setting Personal Reasons for Excuses</strong><br>
                  <small>Make reasons private and only viewable by the director.</small>
                </div>
                <%= link_to "Watch", "https://drive.google.com/file/d/1bta5DqheYcr45o_-3R5R3jmGKXN7F76A/view?usp=drive_link", target: "_blank", rel: "noopener", class: "video-btn" %>
              </li>

              <li class="training-item">
                <div class="training-meta">
                  <strong>Checking into Events</strong><br>
                  <small>Mark yourself as present with a code given by the officers/director.</small>
                </div>
                <%= link_to "Watch", "https://drive.google.com/file/d/1rV6ujeyG1KG6TSlS5eGb6yWqhHH03WtZ/view?usp=drive_link", target: "_blank", rel: "noopener", class: "video-btn" %>
              </li>

            </ul>
          </div>
        </div>

      <% elsif user_signed_in? && (current_user.officer? || current_user.admin?) %>
        <!-- Member Videos (for officers/admins) -->
        <div class="help-card">
          <div class="card-header">
            <h3>Member Videos</h3>
          </div>
          <div class="card-content">
            <ul class="training-list">
              <li class="training-item">
                <div class="training-meta"><strong>Basic Navigation (Member)</strong></div>
                <%= link_to "Watch", "https://drive.google.com/file/d/1OSFrWmGZoiwZF9WRiZ9-L51UhfjSMlX9/view?usp=drive_link", target: "_blank", rel: "noopener", class: "video-btn" %>
              </li>
              <li class="training-item">
                <div class="training-meta"><strong>Submitting One-Time Excuses</strong></div>
                <%= link_to "Watch", "https://drive.google.com/file/d/1Z96sFFqU4518acutYIDmytkzhYGzi-zZ/view?usp=drive_link", target: "_blank", rel: "noopener", class: "video-btn" %>
              </li>
              <li class="training-item">
                <div class="training-meta"><strong>Submitting Recurring Events</strong></div>
                <%= link_to "Watch", "https://drive.google.com/file/d/10hsH0DmpMmicyrC6diEtAY-k5-5MbIie/view?usp=drive_link", target: "_blank", rel: "noopener", class: "video-btn" %>
              </li>
              <li class="training-item">
                <div class="training-meta"><strong>Personal Reasons for Excuses</strong></div>
                <%= link_to "Watch", "https://drive.google.com/file/d/1bta5DqheYcr45o_-3R5R3jmGKXN7F76A/view?usp=drive_link", target: "_blank", rel: "noopener", class: "video-btn" %>
              </li>
              <li class="training-item">
                <div class="training-meta"><strong>Self-Registration to Events</strong></div>
                <%= link_to "Watch", "https://drive.google.com/file/d/1rV6ujeyG1KG6TSlS5eGb6yWqhHH03WtZ/view?usp=drive_link", target: "_blank", rel: "noopener", class: "video-btn" %>
              </li>
            </ul>
          </div>
        </div>

        <!-- Officer/Admin Videos -->
        <div class="help-card">
          <div class="card-header">
            <h3>Officer/Admin Videos</h3>
          </div>
          <div class="card-content">
            <ul class="training-list">
              <li class="training-item">
                <div class="training-meta"><strong>Basic Navigation (Admin)</strong></div>
                <%= link_to "Watch", "https://drive.google.com/file/d/1FfLaliDiCBoGd7meMmNTEbJnIJ1y9BMn/view?usp=drive_link", target: "_blank", rel: "noopener", class: "video-btn" %>
              </li>
              <li class="training-item">
                <div class="training-meta"><strong>Events</strong></div>
                <%= link_to "Watch", "https://drive.google.com/file/d/1AtT20PdkrMeyiTiTlRPpNGKuMav4dzQS/view?usp=drive_link", target: "_blank", rel: "noopener", class: "video-btn" %>
              </li>
              <li class="training-item">
                <div class="training-meta"><strong>Excuses</strong></div>
                <%= link_to "Watch", "https://drive.google.com/file/d/1rwYXwX4Y2uIqsfXt6gf_ry1nqHiXQlwG/view?usp=drive_link", target: "_blank", rel: "noopener", class: "video-btn" %>
              </li>
              <li class="training-item">
                <div class="training-meta"><strong>Member Management</strong></div>
                <%= link_to "Watch", "https://drive.google.com/file/d/1biDun8Q9yr-gODTyUTXOMyg_-CVV4lrU/view?usp=drive_link", target: "_blank", rel: "noopener", class: "video-btn" %>
              </li>
              <li class="training-item">
                <div class="training-meta"><strong>Discipline</strong></div>
                <%= link_to "Watch", "https://drive.google.com/file/d/12dtbu7gy0ORZRJXcFRF8Nj2jCM2EwzEP/view?usp=drive_link", target: "_blank", rel: "noopener", class: "video-btn" %>
              </li>
              <li class="training-item">
                <div class="training-meta"><strong>Registration</strong></div>
                <%= link_to "Watch", "https://drive.google.com/file/d/15N7Rpoa0Y5dVXnJkcqMGAV4lj3DLJZIV/view?usp=drive_link", target: "_blank", rel: "noopener", class: "video-btn" %>
              </li>
              </li>
              <li class="training-item">
                <div class="training-meta"><strong>Website Content Management</strong></div>
                <%= link_to "Watch", "https://drive.google.com/file/d/17Ab6DiR2Ub0k1S135CMmnpqo_AUW1ZT9/view?usp=drive_link", target: "_blank", rel: "noopener", class: "video-btn" %>
              </li>
            </ul>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <!-- CONTACT SECTION -->
  <section class="help-role-section">
    <div class="role-header">
      <h2><span aria-hidden="true">💬</span> Need Help?</h2>
      <p>Contact the right person for your question</p>
    </div>
    
    <% if user_signed_in? && current_user.user? %>
      <div class="contact-card member-contact">
        <h3><span aria-hidden="true">👋</span> Get in Touch with Leadership</h3>
        <p>For questions, issues, or concerns, please reach out to the director:</p>
        <div class="contact-info">
          <p><strong>Director</strong><br>David Kipp — <code>dkipp@tamu.edu</code></p>
        </div>
      </div>
    <% else %>
      <div class="contact-card dev-contact">
        <h3><span aria-hidden="true">👨‍💻</span> Developer Team</h3>
        <p>If you're an officer or admin and found a bug or have a technical issue, please contact the product owner:</p>
        <div class="contact-info">
          <ul class="dev-list">
            <li>Deniz Telci - <code>deniza.telci@tamu.edu</code></li>
          </ul>
        </div>
      </div>
    <% end %>
  </section>
</div>

<style>
  .help-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    min-height: 100vh;
  }

  .help-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .help-header h1 {
    font-size: 2.5rem;
    color: #2c3e50;
    margin: 0 0 10px 0;
  }

  .help-header p {
    font-size: 1.1rem;
    color: #555;
  }

  .help-role-section {
    margin-bottom: 50px;
  }

  .role-header {
    margin-bottom: 30px;
    padding-bottom: 15px;
    border-bottom: 3px solid #500000;
  }

  .role-header h2 {
    font-size: 2rem;
    color: #2c3e50;
    margin: 0 0 5px 0;
  }

  .role-header p {
    color: #666;
    margin: 0;
  }

  .help-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 25px;
    margin-bottom: 30px;
  }

  .help-card {
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .help-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
  }

  .card-header {
    background: linear-gradient(135deg, #500000 0%, #8b0000 100%);
    color: white;
    padding: 20px;
  }

  .card-header h3 {
    margin: 0;
    font-size: 1.3rem;
  }

  .card-content {
    padding: 20px;
  }

  .card-summary {
    cursor: pointer;
    padding: 10px 0;
    display: block;
    user-select: none;
    color: #500000;
    font-weight: 500;
  }

  .card-summary:hover {
    color: #8b0000;
  }

  details > summary {
    list-style: none;
  }

  details > summary::-webkit-details-marker {
    display: none;
  }

  details > summary::before {
    content: '▸ ';
    display: inline-block;
    transition: transform 0.2s;
    color: #500000;
    margin-right: 8px;
  }

  details[open] > summary::before {
    transform: rotate(90deg);
  }

  details {
    margin-bottom: 15px;
  }

  details p, details ol, details ul {
    margin: 10px 0;
    color: #444;
    line-height: 1.6;
  }

  details ol {
    padding-left: 25px;
  }

  details ol li, details ul li {
    margin-bottom: 8px;
  }

  .badge {
    display: inline-block;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: bold;
    margin-right: 5px;
  }

  .badge.pending {
    background-color: #fff3cd;
    color: #856404;
  }

  .badge.approved {
    background-color: #d4edda;
    color: #155724;
  }

  .badge.denied {
    background-color: #f8d7da;
    color: #721c24;
  }

  /* Awaiting admin approval badge */
  .badge.awaiting {
    background-color: #e6f0ff;
    color: #0b66c3;
    border: 1px solid #cfe3ff;
  }

  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-list li {
    padding: 10px 0;
    border-bottom: 1px solid #eee;
  }

  .nav-list li:last-child {
    border-bottom: none;
  }

  .nav-list a {
    color: #500000;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-list a:hover {
    color: #8b0000;
  }

  .training-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Training video card grid + styles */
  .training-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
  }

  .video-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    border-radius: 10px;
    background: #ffffff;
    border: 1px solid #f0f0f0;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }

  .video-thumb {
    flex: 0 0 56px;
    height: 56px;
    border-radius: 8px;
    background: linear-gradient(135deg, #500000 0%, #8b0000 100%);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.15rem;
    box-shadow: 0 4px 10px rgba(80,0,0,0.12);
  }

  .video-meta {
    flex: 1 1 auto;
    min-width: 0;
  }

  .video-meta h4 {
    margin: 0 0 4px 0;
    font-size: 1rem;
  }

  .video-meta p {
    margin: 0;
    color: #666;
    font-size: 0.9rem;
  }

  .video-btn {
    background: #500000;
    color: #fff;
    padding: 8px 12px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: background 0.15s ease;
  }

  .video-btn:hover {
    background: #8b0000;
    color: #fff;
  }

  .training-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .training-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid #eee;
  }

  .training-item .training-meta small {
    color: #666;
    display: block;
    margin-top: 4px;
    font-size: 0.92rem;
  }

  .contact-card {
    background: white;
    border-radius: 12px;
    padding: 30px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    margin-bottom: 20px;
    border-left: 5px solid #500000;
  }

  .contact-card.member-contact { border-left-color: #500000; }
  .contact-card.dev-contact    { border-left-color: #8b0000; }

  .contact-card h3 {
    margin: 0 0 10px 0;
    color: #2c3e50;
    font-size: 1.2rem;
  }

  .contact-card p { color: #666; margin: 0 0 15px 0; }

  .contact-info {
    background-color: #f8f9fa;
    padding: 15px;
    border-radius: 8px;
    border: 1px solid #eef2f5;
  }

  .contact-info p { margin: 8px 0; color: #333; }

  .dev-list { list-style: none; padding: 0; margin: 0; }
  .dev-list li { padding: 6px 0; color: #333; }

  @media (max-width: 768px) {
    .help-header h1 {
      font-size: 1.8rem;
    }

    .role-header h2 {
      font-size: 1.5rem;
    }

    .help-grid {
      grid-template-columns: 1fr;
    }

    .training-grid {
      grid-template-columns: 1fr;
    }

    .video-card {
      align-items: flex-start;
    }

    .training-item {
      flex-direction: column;
      align-items: flex-start;
    }

    .training-item .video-btn {
      margin-top: 8px;
    }
  }
</style>
