<!-- Breadcrumb Navigation -->
<nav aria-label="breadcrumb" class="mb-4">
  <ol class="breadcrumb">
    <li class="breadcrumb-item">
      <%= link_to internal_events_path, class: "text-decoration-none" do %>
        <i class="bi bi-calendar-event me-1"></i>Events
      <% end %>
    </li>
    <li class="breadcrumb-item">
      <%= link_to @event.title, internal_event_path(@event), class: "text-decoration-none" %>
    </li>
    <li class="breadcrumb-item active" aria-current="page">Check In</li>
  </ol>
</nav>

<!-- Self Check-in Card -->
<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <div class="card shadow-sm border-0">
      <!-- Card Header -->
      <div class="card-header bg-success text-white py-4 text-center">
        <i class="bi bi-qr-code display-4 mb-3"></i>
        <h2 class="mb-2">Check In</h2>
        <p class="mb-0 text-white-50"><%= @event.title %></p>
      </div>

      <!-- Card Body -->
      <div class="card-body p-4">
        <!-- Event Details -->
        <div class="mb-4 p-3 bg-light rounded">
          <div class="d-flex align-items-center mb-2">
            <i class="bi bi-calendar3 text-primary me-2"></i>
            <strong class="me-2">Date:</strong>
            <span class="text-muted">
              <%= @event.date.strftime("%B %d, %Y at %l:%M %p") %>
            </span>
          </div>
          <div class="d-flex align-items-center">
            <i class="bi bi-geo-alt text-primary me-2"></i>
            <strong class="me-2">Location:</strong>
            <span class="text-muted"><%= @event.location %></span>
          </div>
        </div>

        <!-- Instructions -->
        <div class="mb-4">
          <h5 class="text-dark mb-3">
            <i class="bi bi-info-circle text-primary me-2"></i>How to Check In
          </h5>
          <ol class="ps-3 mb-0">
            <li class="mb-2">Get the 4-digit passcode from the event organizer</li>
            <li class="mb-2">Enter the passcode below</li>
            <li>Click "Check In" to mark your attendance</li>
          </ol>
        </div>

        <!-- Passcode Form -->
        <%= form_with url: self_checkin_internal_event_path(@event), method: :post, local: true, class: "needs-validation" do |form| %>
          <div class="mb-4">
            <%= label_tag :passcode, "Enter Passcode", class: "form-label fw-bold" %>
            <%= text_field_tag :passcode, nil, 
                class: "form-control form-control-lg text-center font-monospace", 
                placeholder: "0000",
                maxlength: 4,
                pattern: "[0-9]{4}",
                required: true,
                autofocus: true,
                inputmode: "numeric",
                autocomplete: "off" %>
            <div class="form-text text-center">
              <i class="bi bi-shield-lock me-1"></i>
              Enter the 4-digit numeric code
            </div>
          </div>

          <!-- Submit Button -->
          <div class="d-grid gap-2 mb-3">
            <%= submit_tag "Check In", class: "btn btn-success btn-lg" %>
            <%= link_to "Cancel", internal_event_path(@event), class: "btn btn-outline-secondary" %>
          </div>
        <% end %>

        <!-- Security Notice -->
        <div class="alert alert-warning bg-warning bg-opacity-10 border-warning">
          <small>
            <i class="bi bi-exclamation-triangle me-1"></i>
            <strong>Note:</strong> You can only check in once. Self check-in is only available from 10 minutes before to 10 minutes after the event.
          </small>
        </div>
      </div>
    </div>

    <!-- Help Card -->
    <div class="card shadow-sm border-0 mt-3">
      <div class="card-body">
        <h6 class="card-title">
          <i class="bi bi-question-circle text-primary me-2"></i>Need Help?
        </h6>
        <p class="card-text small text-muted mb-0">
          If you're having trouble checking in, please contact an event organizer or officer for assistance.
        </p>
      </div>
    </div>
  </div>
</div>

<!-- Input Validation Script -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const passcodeInput = document.getElementById('passcode');
    
    // Only allow numeric input
    passcodeInput.addEventListener('input', function(e) {
      this.value = this.value.replace(/[^0-9]/g, '');
      
      // Limit to 4 digits
      if (this.value.length > 4) {
        this.value = this.value.slice(0, 4);
      }
    });

    // Auto-submit when 4 digits are entered (optional)
    passcodeInput.addEventListener('input', function(e) {
      if (this.value.length === 4) {
        // Optional: Auto-focus submit button
        // this.form.querySelector('input[type="submit"]').focus();
      }
    });
  });
</script>

<!-- Custom Styles -->
<style>
  .font-monospace {
    letter-spacing: 0.5rem;
  }
  
  .card {
    transition: transform 0.2s ease-in-out;
  }
  
  .card:hover {
    transform: translateY(-2px);
  }
  
  .bg-opacity-10 {
    --bs-bg-opacity: 0.1;
  }
</style>

