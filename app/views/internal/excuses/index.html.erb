<div class="d-flex align-items-center justify-content-between mb-4">
  <h1 class="display-5 fw-bold">Excuses</h1>
  <% if !(current_user.admin? || current_user.officer?) %>
    <%= link_to 'Submit Excuse', new_internal_excuse_path, class: 'btn btn-primary' %>
  <% end %>
</div>
<p class="text-muted mb-0">View and submit excuse requests</p>

<%# Buckets updated to include the new 'Pending Section Leader Review' status %>
<% pending_admin = @excuses.select { |e| e.status == 'pending' && e.officer_status.present? } %>
<% pending = @excuses.select { |e| (e.status == 'pending' || e.status == 'Pending Section Leader Review') && e.officer_status.blank? } %>
<% approved = @excuses.select { |e| e.status == 'approved' } %>
<% denied = @excuses.select { |e| e.status == 'denied' } %>

<% sections = [
  { title: 'Pending Admin Approval', items: pending_admin, css: 'text-info' },
  { title: 'Pending', items: pending, css: 'text-warning' },
  { title: 'Approved', items: approved, css: 'text-success' },
  { title: 'Denied', items: denied, css: 'text-danger' }
] %>

<% sections.each do |section| %>
  <% next if section[:items].empty? %>
  <div class="mb-5">
    <h2 class="h4 fw-semibold mb-3 <%= section[:css] %>"><%= section[:title] %> Excuses</h2>
    <div class="row g-4">
      <% section[:items].each do |excuse| %>
        <% display_status = excuse.status %>

        <div class="col-md-6 col-lg-4">
          <div class="card shadow-sm h-100">
            <div class="card-header bg-primary text-white">
              <strong>
                <% if excuse.events.any? %>
                  <% primary_event = excuse.events.order(date: :asc).first %>
                  <%= primary_event.title %>
                  <% if excuse.events.size > 1 %>
                    <span class="text-light ms-2 small">(+<%= excuse.events.size - 1 %> more)</span>
                  <% end %>
                <% else %>
                  —
                <% end %>
              </strong>
              <% if excuse.recurring? %>
                <span class="badge bg-info float-end">Recurring</span>
              <% end %>
            </div>
            <div class="card-body d-flex flex-column">
              <div class="d-flex align-items-center mb-2">
                <i class="bi bi-calendar3 text-primary me-2"></i>
                <% if excuse.events.one? %>
                  <% e = excuse.events.order(date: :asc).first %>
                  <span class="fw-medium"><%= e.date.strftime("%A, %B %d, %Y at %I:%M %p") rescue '—' %></span>
                <% elsif excuse.events.any? %>
                  <span class="fw-medium">Multiple dates</span>
                <% else %>
                  <span class="fw-medium">—</span>
                <% end %>
              </div>

              <% if current_user.admin? || current_user.officer? %>
                <p class="mb-1"><strong>Member:</strong> <%= excuse.member.full_name %></p>
              <% end %>
              <p class="mb-1"><strong>Submitted:</strong> <%= excuse.submission_date&.in_time_zone('Central Time (US & Canada)')&.strftime("%B %d, %Y at %I:%M %p") %></p>
              <p class="mb-1"><strong>Status:</strong>
                <span class="badge 
                  <%= case display_status
                    when 'pending', 'Pending Section Leader Review' then 'bg-warning text-dark'
                    when 'denied' then 'bg-danger'
                    when 'approved' then 'bg-success'
                    else 'bg-secondary'
                  end %>">
                  <%= case display_status
                    when 'Pending Section Leader Review' then 'Pending Officer Review'
                    when 'pending' then 'Pending Director Approval'
                    else display_status.to_s.capitalize
                  end %>
                </span>
              </p>

              <% if excuse.reviewer_entries.any? %>
                <% first_entry = excuse.reviewer_entries.first %>
                <% reviewer = first_entry.reviewer %>
                <p class="mb-1">
                  <strong>Reviewed:</strong>
                  <%= reviewer.full_name %>
                  <% if reviewer.role == 'officer' %>
                    <span class="badge bg-warning ms-2">Officer</span>
                  <% elsif reviewer.role.in?(%w[admin super_admin]) %>
                    <span class="badge bg-danger ms-2">Admin</span>
                  <% end %>
                  <% if excuse.reviewer_entries.size > 1 %>
                    <span class="text-muted small">(+<%= excuse.reviewer_entries.size - 1 %> more)</span>
                  <% end %>
                </p>
              <% end %>

              <div class="mt-auto pt-2 d-flex gap-2">
                <%= link_to internal_excuse_path(excuse), class: "btn btn-outline-primary btn-sm flex-fill" do %>
                  <i class="bi bi-eye me-1"></i>View Details
                <% end %>
                <% if excuse.editable_and_deletable_by_member?(current_user) %>
                  <%= link_to edit_internal_excuse_path(excuse), class: "btn btn-outline-secondary btn-sm flex-fill" do %>
                    <i class="bi bi-pencil me-1"></i>Edit
                  <% end %>
                  <%= button_to internal_excuse_path(excuse), method: :delete, form_class: "flex-fill m-0 d-flex", class: "btn btn-outline-danger btn-sm w-100", data: { confirm: 'Are you sure you want to delete this excuse? This cannot be undone.' } do %>
                    <i class="bi bi-trash me-1"></i>Delete
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>