<%= form_with model: excuse, url: excuse.persisted? ? internal_excuse_path(excuse) : internal_excuses_path, local: true, id: "excuse-form" do |f| %>
  
  <% if excuse.errors.any? %>
    <div class="alert alert-danger">
      <h6 class="alert-heading fw-bold mb-1">Please fix the following problems:</h6>
      <ul class="mb-0 small">
        <% excuse.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- AC1: Recurring toggle (The Switch) -->
  <div class="mb-4 form-check form-switch">
    <%= f.check_box :recurring, class: "form-check-input", id: "recurring-toggle", style: "width: 2.5em; height: 1.25em;", checked: excuse.recurring? %>
    <%= f.label :recurring, "Mark as Recurring Excuse", class: "form-check-label ms-2 fw-bold" %>
  </div>

  <!-- MODE A: SINGLE EXCUSE FIELDS -->
  <div id="single-fields">
    <div class="mb-3">
      <label class="form-label text-muted small fw-bold">Filter Events by Date</label>
      <input type="date" id="event-date-filter" class="form-control">
    </div>

    <div class="mb-3">
      <label class="form-label text-muted small fw-bold">Events (select one or more)</label>
      <%= f.select :event_ids, 
            Event.upcoming.map { |e| ["#{e.title} (#{e.date.strftime('%B %d, %Y %I:%M %p')})", e.id, { 'data-date': e.date.to_date }] }, 
            { selected: excuse.events.map(&:id) }, 
            { multiple: true, class: "form-select", size: 8, id: "event-select" } %>
      <div class="form-text small">Hold Ctrl (Cmd) to select multiple events.</div>
    </div>
  </div>

  <!-- MODE B: RECURRING FIELDS -->
  <div id="recurring-fields" style="display: none;">
    <label class="form-label text-muted small fw-bold">Day(s) of the Week</label>
    <div class="d-flex flex-wrap gap-2 mb-3">
      <% %w[Sun Mon Tue Wed Thu Fri Sat].each_with_index do |day, i| %>
        <div class="form-check form-check-inline">
          <input type="checkbox" class="form-check-input day-cb" id="day_<%= i %>" value="<%= i %>" <%= 'checked' if excuse.recurring_days_array.include?(i) %>>
          <label class="form-check-label small" for="day_<%= i %>"><%= day %></label>
        </div>
      <% end %>
    </div>
    <%= f.hidden_field :recurring_days, id: "recurring-days-hidden" %>

    <div class="row">
      <div class="col-6 mb-3">
        <%= f.label :start_date, "Start Date", class: "form-label text-muted small fw-bold" %>
        <%= f.date_field :start_date, class: "form-control" %>
      </div>
      <div class="col-6 mb-3">
        <%= f.label :end_date, "End Date", class: "form-label text-muted small fw-bold" %>
        <%= f.date_field :end_date, class: "form-control" %>
      </div>
    </div>

    <label class="form-label text-muted small fw-bold">Time Range (events must fall within this window)</label>
    <div class="row">
      <div class="col-6 mb-3">
        <%= f.label :recurring_start_time, "From", class: "form-label text-muted small" %>
        <%= f.time_field :recurring_start_time, class: "form-control" %>
      </div>
      <div class="col-6 mb-3">
        <%= f.label :recurring_end_time, "To", class: "form-label text-muted small" %>
        <%= f.time_field :recurring_end_time, class: "form-control" %>
      </div>
    </div>
    <div class="form-text small mb-3">Only events starting within this time window on the selected days will be linked.</div>
  </div>

  <!-- COMMON FIELDS -->
  <div class="mb-3">
    <%= f.label :reason, "Reason", class: "form-label text-muted small fw-bold" %>
    <%= f.text_area :reason, class: "form-control", rows: 3 %>
  </div>

  <div class="mb-4">
    <%= f.label :proof_link, "Proof link", class: "form-label text-muted small fw-bold" %>
    <%= f.text_field :proof_link, class: "form-control", placeholder: "https://example.com/proof" %>
    <div class="form-text small text-danger"><i class="bi bi-exclamation-triangle"></i> Note: Proof must be attached within a day after the event takes place to avoid discipline points.</div>
  </div>

  <div class="d-flex justify-content-between pt-3 border-top">
    <%= link_to "Cancel", (excuse.persisted? ? internal_excuse_path(excuse) : internal_excuses_path), class: "btn btn-secondary px-4" %>
    <%= f.submit (excuse.persisted? ? "Update Excuse" : "Submit Excuse"), class: "btn btn-primary px-4" %>
  </div>
<% end %>

<script>
  function setupExcuseToggle() {
    const toggle = document.getElementById("recurring-toggle");
    const singleDiv = document.getElementById("single-fields");
    const recurringDiv = document.getElementById("recurring-fields");
    const dateFilter = document.getElementById("event-date-filter");
    const eventSelect = document.getElementById("event-select");
    const hiddenDaysInput = document.getElementById("recurring-days-hidden");
    const dayCheckboxes = document.querySelectorAll(".day-cb");

    if (!toggle || !singleDiv || !recurringDiv) return;

    function updateFormMode() {
      if (toggle.checked) {
        singleDiv.style.display = "none";
        recurringDiv.style.display = "block";
      } else {
        singleDiv.style.display = "block";
        recurringDiv.style.display = "none";
      }
    }

    if (dateFilter && eventSelect) {
      dateFilter.addEventListener("change", function() {
        const selectedDate = this.value;
        Array.from(eventSelect.options).forEach(opt => {
          const optDate = opt.getAttribute("data-date");
          opt.style.display = (!selectedDate || optDate === selectedDate) ? "block" : "none";
        });
      });
    }

    function syncDays() {
      let selected = [];
      dayCheckboxes.forEach(cb => { if(cb.checked) selected.push(cb.value); });
      hiddenDaysInput.value = selected.join(",");
    }

    toggle.addEventListener("change", updateFormMode);
    dayCheckboxes.forEach(cb => cb.addEventListener("change", syncDays));
    
    updateFormMode();
    syncDays();
  }

  document.addEventListener("turbo:load", setupExcuseToggle);
  document.addEventListener("turbolinks:load", setupExcuseToggle);
  document.addEventListener("DOMContentLoaded", setupExcuseToggle);
</script>
