<!-- Breadcrumb Navigation -->
<nav aria-label="breadcrumb" class="mb-4">
  <ol class="breadcrumb">
    <li class="breadcrumb-item">
      <%= link_to internal_events_path, class: "text-decoration-none" do %>
        <i class="bi bi-house me-1"></i>Dashboard
      <% end %>
    </li>
    <li class="breadcrumb-item">
      <%= link_to internal_demerits_path, class: "text-decoration-none" do %>
        <i class="bi bi-exclamation-triangle me-1"></i>Discipline Points
      <% end %>
    </li>
    <li class="breadcrumb-item">
      <%= link_to internal_demerit_path(@demerit), class: "text-decoration-none" do %>
        Record #<%= @demerit.id %>
      <% end %>
    </li>
    <li class="breadcrumb-item active" aria-current="page">Edit</li>
  </ol>
</nav>

<!-- Page Header -->
<div class="mb-4 text-center">
  <h1 class="h2 fw-bold text-dark mb-2">
    <i class="bi bi-pencil me-2 text-warning"></i>Edit Discipline Points
  </h1>
  <p class="text-muted mb-0">
    <i class="bi bi-info-circle me-1"></i>Modify discipline points for <%= @demerit.member.full_name %>
  </p>
</div>

<%= render 'form', demerit: @demerit, heading: "Edit Discipline Points", submit_text: "Update Record" %>