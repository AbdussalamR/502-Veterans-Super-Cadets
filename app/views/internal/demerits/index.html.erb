<!-- Breadcrumb Navigation -->
<nav aria-label="breadcrumb" class="mb-4">
  <ol class="breadcrumb">
    <li class="breadcrumb-item">
      <%= link_to internal_events_path, class: "text-decoration-none" do %>
        <i class="bi bi-house me-1"></i>Dashboard
      <% end %>
    </li>
    <li class="breadcrumb-item active" aria-current="page">Discipline Points</li>
  </ol>
</nav>

<!-- Page Header -->
<div class="card shadow-sm border-0 mb-4">
  <div class="card-header bg-warning text-white border-0 py-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
      <div>
        <h1 class="h2 mb-2 text-white">
          <i class="bi bi-exclamation-triangle me-2"></i>Discipline Points Management
        </h1>
        <p class="mb-0 text-white-50">
          <i class="bi bi-info-circle me-2"></i>Track and manage member discipline points
        </p>
      </div>
      <div class="d-flex gap-2 flex-wrap">
        <%= link_to new_internal_demerit_path, class: "btn btn-light" do %>
          <i class="bi bi-plus-circle me-2"></i>Add Discipline Points
        <% end %>
        <%= link_to absence_report_internal_users_path, class: "btn btn-outline-light" do %>
          <i class="bi bi-calendar-x me-2"></i>Absence Report
        <% end %>
        <%= link_to internal_users_path, class: "btn btn-outline-light" do %>
          <i class="bi bi-people me-2"></i>Member List
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Statistics Dashboard -->
<div class="row g-3 mb-4">
  <div class="col-md-6 col-lg-3">
    <div class="card bg-primary bg-opacity-10 border-0 shadow-sm h-100">
      <div class="card-body text-center p-4">
        <div class="display-6 text-primary mb-2">
          <i class="bi bi-exclamation-triangle-fill"></i>
        </div>
        <h3 class="text-primary mb-1"><%= @demerits.count %></h3>
        <small class="text-muted">Total Discipline Records</small>
      </div>
    </div>
  </div>
  <div class="col-md-6 col-lg-3">
    <div class="card bg-warning bg-opacity-10 border-0 shadow-sm h-100">
      <div class="card-body text-center p-4">
        <div class="display-6 text-warning mb-2">
          <i class="bi bi-calculator-fill"></i>
        </div>
        <h3 class="text-warning mb-1"><%= @demerits.sum(:value).round(2) %></h3>
        <small class="text-muted">Total Value</small>
      </div>
    </div>
  </div>
  <div class="col-md-6 col-lg-3">
    <div class="card bg-info bg-opacity-10 border-0 shadow-sm h-100">
      <div class="card-body text-center p-4">
        <div class="display-6 text-info mb-2">
          <i class="bi bi-people-fill"></i>
        </div>
        <h3 class="text-info mb-1"><%= @demerits.select(:member_id).distinct.count %></h3>
        <small class="text-muted">Affected Members</small>
      </div>
    </div>
  </div>
  <div class="col-md-6 col-lg-3">
    <div class="card bg-success bg-opacity-10 border-0 shadow-sm h-100">
      <div class="card-body text-center p-4">
        <div class="display-6 text-success mb-2">
          <i class="bi bi-calendar-month-fill"></i>
        </div>
        <h3 class="text-success mb-1"><%= @demerits.where("date >= ?", Time.current.beginning_of_month).count %></h3>
        <small class="text-muted">This Month</small>
      </div>
    </div>
  </div>
</div>

<!-- Demerits Table -->
<div class="card shadow-sm border-0">
  <div class="card-header bg-light border-0">
    <h5 class="mb-0">
      <i class="bi bi-list-ul text-primary me-2"></i>All Discipline Points
    </h5>
  </div>
  <div class="card-body p-0">
    <% if @demerits.empty? %>
      <div class="text-center py-5">
        <div class="display-1 text-success mb-3">
          <i class="bi bi-emoji-smile"></i>
        </div>
        <h5 class="text-muted mb-2">No Discipline Points Yet</h5>
        <p class="text-muted mb-0">No discipline points have been issued yet.</p>
      </div>
    <% else %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>
                <i class="bi bi-person me-1"></i>Member
              </th>
              <th>
                <i class="bi bi-hash me-1"></i>Value
              </th>
              <th>
                <i class="bi bi-chat-square-text me-1"></i>Reason
              </th>
              <th>
                <i class="bi bi-calendar3 me-1"></i>Date
              </th>
              <th>
                <i class="bi bi-person-badge me-1"></i>Given By
              </th>
              <th class="text-center">
                <i class="bi bi-gear me-1"></i>Actions
              </th>
            </tr>
          </thead>
          <tbody>
            <% @demerits.each do |demerit| %>
              <tr>
                <td>
                  <%= link_to internal_user_path(demerit.member), class: "text-decoration-none" do %>
                    <div>
                      <div class="fw-medium text-dark"><%= demerit.member.full_name %></div>
                      <small class="text-muted">
                        <i class="bi bi-envelope me-1"></i><%= truncate(demerit.member.email, length: 25) %>
                      </small>
                    </div>
                  <% end %>
                </td>
                <td>
                  <span class="badge bg-danger fs-6 px-3"><%= demerit.value %></span>
                  <div class="mt-1">
                    <small class="text-muted">(<%= format_absence_points(demerit.absence_points) %> pts)</small>
                  </div>
                </td>
                <td>
                  <span class="text-muted"><%= truncate(demerit.reason, length: 40) %></span>
                </td>
                <td class="text-muted">
                  <%= demerit.date.strftime("%b %d, %Y") %>
                  <br>
                  <small><%= demerit.date.strftime("%I:%M %p") %></small>
                </td>
                <td class="text-muted">
                  <i class="bi bi-person-circle me-1"></i><%= demerit.given_by.full_name %>
                </td>
                <td>
                  <div class="btn-group" role="group">
                    <%= link_to internal_demerit_path(demerit), class: "btn btn-sm btn-outline-primary", title: "View Details" do %>
                      <i class="bi bi-eye"></i>
                    <% end %>
                    <%= link_to edit_internal_demerit_path(demerit), class: "btn btn-sm btn-outline-warning", title: "Edit" do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                    <%= button_to internal_demerit_path(demerit, source: 'demerits_index'), 
                          method: :delete,
                          form: { style: 'display: inline-block;' },
                          data: { turbo_confirm: "Are you sure you want to delete this discipline point record?" },
                          class: "btn btn-sm btn-outline-danger",
                          title: "Delete" do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>

<!-- Custom Styles -->
<style>
  .card {
    transition: transform 0.2s ease-in-out;
    position: relative;
    z-index: 1;
  }
  
  .card:hover {
    transform: translateY(-1px);
    z-index: 10;
  }
  
  .bg-opacity-10 {
    --bs-bg-opacity: 0.1;
  }

  .table > :not(caption) > * > * {
    padding: 1rem 0.75rem;
  }
</style>