<% content_for :title, "Registration Approval" %>

<!-- Page Header with Statistics -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="display-5 fw-bold text-dark mb-1">
      <i class="bi bi-person-check me-2 text-primary"></i>Registration Approval
    </h1>
    <p class="text-muted mb-0">Review and manage member registration requests</p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to internal_users_path, class: "btn btn-outline-primary" do %>
      <i class="bi bi-people me-2"></i>Member Management
    <% end %>
    <%= link_to internal_events_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
    <% end %>
  </div>
</div>

<!-- Statistics Dashboard -->
<div class="row mb-5">
  <div class="col-md-3">
    <div class="card bg-warning bg-opacity-10 border-warning border-opacity-25 h-100">
      <div class="card-body text-center">
        <div class="display-4 text-warning mb-2">
          <i class="bi bi-clock-history"></i>
        </div>
        <h3 class="text-warning mb-1"><%= @pending_users.count %></h3>
        <p class="text-muted mb-0">Pending Review</p>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card bg-success bg-opacity-10 border-success border-opacity-25 h-100">
      <div class="card-body text-center">
        <div class="display-4 text-success mb-2">
          <i class="bi bi-check-circle"></i>
        </div>
        <h3 class="text-success mb-1"><%= @approved_users.count %></h3>
        <p class="text-muted mb-0">Approved Members</p>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card bg-danger bg-opacity-10 border-danger border-opacity-25 h-100">
      <div class="card-body text-center">
        <div class="display-4 text-danger mb-2">
          <i class="bi bi-x-circle"></i>
        </div>
        <h3 class="text-danger mb-1"><%= @rejected_users.count %></h3>
        <p class="text-muted mb-0">Rejected</p>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card bg-primary bg-opacity-10 border-primary border-opacity-25 h-100">
      <div class="card-body text-center">
        <div class="display-4 text-primary mb-2">
          <i class="bi bi-people"></i>
        </div>
        <h3 class="text-primary mb-1"><%= @pending_users.count + @approved_users.count + @rejected_users.count %></h3>
        <p class="text-muted mb-0">Total Registrations</p>
      </div>
    </div>
  </div>
</div>

<!-- Search Controls -->
<%= form_with url: admin_registrations_path, method: :get, local: true, class: "mb-4" do |form| %>
  <div class="row">
    <div class="col-md-8">
      <div class="input-group">
        <span class="input-group-text">
          <i class="bi bi-search"></i>
        </span>
        <%= form.text_field :search, 
            value: @search_term, 
            placeholder: "Search registrations by name or email...", 
            class: "form-control" %>
      </div>
    </div>
    <div class="col-md-2">
      <%= form.submit "Search", class: "btn btn-primary" %>
    </div>
    <div class="col-md-2">
      <% if @search_term.present? %>
        <%= link_to "Clear", admin_registrations_path, class: "btn btn-outline-secondary" %>
      <% end %>
    </div>
  </div>
<% end %>

<!-- Search Results Info -->
<% if @search_term.present? %>
  <div class="alert alert-info mb-4">
    <i class="bi bi-info-circle me-2"></i>
    Showing registrations matching "<%= @search_term %>"
  </div>
<% end %>

<!-- Pending Registrations Section -->
<div class="mb-5">
  <div class="d-flex align-items-center mb-4">
    <div class="me-3">
      <div class="bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
        <i class="bi bi-clock-history text-warning display-6"></i>
      </div>
    </div>
    <div>
      <h2 class="h3 text-dark mb-1">
        Pending Registrations
        <% if @pending_users.any? %>
          <span class="badge bg-warning ms-2"><%= @pending_users.count %></span>
        <% end %>
      </h2>
      <p class="text-muted mb-0">Members awaiting approval to access the system</p>
    </div>
  </div>

  <% if @pending_users.any? %>
    <div class="row g-4">
      <% @pending_users.each do |user| %>
        <div class="col-lg-6 col-xl-4">
          <div class="card shadow-sm border-0 hover-lift h-100">
            <!-- User Header -->
            <div class="card-header bg-warning bg-opacity-10 border-0 py-3">
              <div class="d-flex align-items-center">
                <div class="me-3">
                  <i class="bi bi-person-circle display-5 text-warning"></i>
                </div>
                <div class="flex-grow-1">
                  <h6 class="card-title mb-1 fw-bold text-dark">
                    <%= user.full_name %>
                  </h6>
                  <span class="badge bg-warning text-dark">
                    <i class="bi bi-clock me-1"></i>Pending Review
                  </span>
                </div>
              </div>
            </div>

            <!-- User Details -->
            <div class="card-body">
              <div class="mb-3">
                <div class="d-flex align-items-center mb-2">
                  <i class="bi bi-envelope text-muted me-2"></i>
                  <small class="text-muted"><%= user.email %></small>
                </div>
                <div class="d-flex align-items-center mb-2">
                  <i class="bi bi-person-badge text-muted me-2"></i>
                  <small class="text-muted">Role: <%= user.role_display_name %></small>
                </div>
                <div class="d-flex align-items-center">
                  <i class="bi bi-calendar3 text-muted me-2"></i>
                  <small class="text-muted">Registered <%= time_ago_in_words(user.created_at) %> ago</small>
                </div>
              </div>
            </div>

            <!-- Action Buttons -->
            <div class="card-footer bg-light border-0">
              <div class="d-grid gap-2">
                <%= button_to approve_admin_registration_path(user), method: :patch, 
                    class: "btn btn-success btn-sm", 
                    data: { confirm: "Are you sure you want to approve #{user.full_name}'s registration?" } do %>
                  <i class="bi bi-check-circle me-2"></i>Approve Registration
                <% end %>
                <%= button_to reject_admin_registration_path(user), method: :patch, 
                    class: "btn btn-outline-danger btn-sm", 
                    data: { confirm: "Are you sure you want to reject #{user.full_name}'s registration?" } do %>
                  <i class="bi bi-x-circle me-2"></i>Reject
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-5">
      <div class="card border-0 bg-light">
        <div class="card-body py-5">
          <i class="bi bi-check-circle-fill text-success display-1 mb-3"></i>
          <h4 class="text-dark mb-2">All Caught Up!</h4>
          <p class="text-muted">There are no pending registration requests to review.</p>
        </div>
      </div>
    </div>
  <% end %>
</div>

<!-- Approved Registrations Section -->
<div class="mb-5">
  <div class="d-flex align-items-center mb-4">
    <div class="me-3">
      <div class="bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
        <i class="bi bi-check-circle text-success display-6"></i>
      </div>
    </div>
    <div>
      <h2 class="h3 text-dark mb-1">
        Approved Members
        <% if @approved_users.any? %>
          <span class="badge bg-success ms-2"><%= @approved_users.count %></span>
        <% end %>
      </h2>
      <p class="text-muted mb-0">Members with approved access to the system</p>
    </div>
  </div>

  <% if @approved_users.any? %>
    <div class="row g-3">
      <% @approved_users.limit(12).each do |user| %>
        <div class="col-lg-4 col-xl-3">
          <div class="card border-0 bg-success bg-opacity-5 hover-lift-sm">
            <div class="card-body p-3">
              <div class="d-flex justify-content-between align-items-start">
                <div class="d-flex align-items-center">
                  <div class="me-2">
                    <i class="bi bi-person-circle display-6 text-success"></i>
                  </div>
                  <div>
                    <h6 class="mb-1 text-dark"><%= truncate(user.full_name, length: 20) %></h6>
                    <small class="text-muted d-block"><%= user.role_display_name %></small>
                    <small class="text-muted">
                      <i class="bi bi-calendar3 me-1"></i><%= user.created_at.strftime("%m/%d/%y") %>
                    </small>
                  </div>
                </div>
                <div class="dropdown">
                  <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-three-dots"></i>
                  </button>
                  <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                      <%= link_to internal_user_path(user), class: "dropdown-item" do %>
                        <i class="bi bi-eye me-2"></i>View Profile
                      <% end %>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                      <%= button_to reject_admin_registration_path(user), method: :patch,
                          data: { confirm: "Are you sure you want to reject #{user.full_name}?" },
                          class: "dropdown-item text-danger border-0 bg-transparent w-100 text-start" do %>
                        <i class="bi bi-x-circle me-2"></i>Reject Access
                      <% end %>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
      <% if @approved_users.count > 12 %>
        <div class="col-12">
          <div class="text-center">
            <%= link_to internal_users_path, class: "btn btn-outline-success" do %>
              <i class="bi bi-eye me-2"></i>View All <%= @approved_users.count %> Approved Members
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-light border">
      <i class="bi bi-info-circle me-2"></i>
      No approved registrations yet.
    </div>
  <% end %>
</div>

<!-- Rejected Registrations Section -->
<div class="mb-5">
  <div class="d-flex align-items-center mb-4">
    <div class="me-3">
      <div class="bg-danger bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
        <i class="bi bi-x-circle text-danger display-6"></i>
      </div>
    </div>
    <div>
      <h2 class="h3 text-dark mb-1">
        Rejected Registrations
        <% if @rejected_users.any? %>
          <span class="badge bg-danger ms-2"><%= @rejected_users.count %></span>
        <% end %>
      </h2>
      <p class="text-muted mb-0">Members who have been denied access</p>
    </div>
  </div>

  <% if @rejected_users.any? %>
    <div class="row g-3">
      <% @rejected_users.each do |user| %>
        <div class="col-lg-4 col-xl-3">
          <div class="card border-0 bg-danger bg-opacity-5 hover-lift-sm">
            <div class="card-body p-3">
              <div class="d-flex justify-content-between align-items-start">
                <div class="d-flex align-items-center">
                  <div class="me-2">
                    <i class="bi bi-person-circle display-6 text-danger"></i>
                  </div>
                  <div>
                    <h6 class="mb-1 text-dark"><%= truncate(user.full_name, length: 20) %></h6>
                    <small class="text-muted d-block"><%= user.role_display_name %></small>
                    <small class="text-muted">
                      <i class="bi bi-calendar3 me-1"></i><%= user.created_at.strftime("%m/%d/%y") %>
                    </small>
                  </div>
                </div>
                <div class="dropdown">
                  <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-three-dots"></i>
                  </button>
                  <ul class="dropdown-menu dropdown-menu-end">
                    <li>
                      <%= button_to approve_admin_registration_path(user), method: :patch,
                          data: { confirm: "Are you sure you want to approve #{user.full_name}?" },
                          class: "dropdown-item text-success border-0 bg-transparent w-100 text-start" do %>
                        <i class="bi bi-check-circle me-2"></i>Approve Access
                      <% end %>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                      <%= button_to destroy_rejected_admin_registration_path(user), method: :delete,
                          data: { confirm: "Are you sure you want to PERMANENTLY DELETE #{user.full_name}? This action cannot be undone and will remove all their data." },
                          class: "dropdown-item text-danger border-0 bg-transparent w-100 text-start" do %>
                        <i class="bi bi-trash me-2"></i>Delete User
                      <% end %>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-light border">
      <i class="bi bi-info-circle me-2"></i>
      No rejected registrations.
    </div>
  <% end %>
</div>

<!-- Custom Styles -->
<style>
  .hover-lift {
    transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    position: relative;
    z-index: 1;
  }
  
  .hover-lift:hover {
    transform: translateY(-2px);
    box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    z-index: 10;
  }
  
  .hover-lift-sm {
    transition: transform 0.2s ease-in-out;
    position: relative;
    z-index: 1;
  }
  
  .hover-lift-sm:hover {
    transform: translateY(-1px);
    z-index: 10;
  }
  
  .bg-opacity-5 {
    --bs-bg-opacity: 0.05;
  }
  
  .border-opacity-25 {
    --bs-border-opacity: 0.25;
  }

  /* Mobile-Friendly Styles for Registration Approval */
  @media (max-width: 768px) {
    /* Header responsive layout */
    .d-flex.justify-content-between.align-items-center.mb-4 {
      flex-direction: column !important;
      align-items: flex-start !important;
      gap: 1rem;
    }

    .d-flex.justify-content-between.align-items-center.mb-4 > div:last-child {
      width: 100%;
    }

    .d-flex.gap-2 {
      width: 100%;
      flex-direction: column;
      gap: 0.5rem !important;
    }

    /* Page title sizing */
    h1.display-5 {
      font-size: 1.75rem !important;
    }

    .display-5 p.text-muted {
      font-size: 0.875rem !important;
    }

    /* Statistics cards - full width on mobile */
    .row.mb-5 > div[class*="col-md-3"] {
      width: 100%;
      margin-bottom: 0.75rem;
    }

    .card-body .display-4 {
      font-size: 2rem !important;
    }

    /* Search form - stack inputs vertically */
    .row > div[class*="col-md-"] {
      width: 100%;
      margin-bottom: 0.5rem;
    }

    .input-group {
      margin-bottom: 0.5rem;
    }

    .btn {
      width: 100%;
      min-height: 44px;
    }

    /* Section headers more compact */
    .d-flex.align-items-center.mb-4 h2 {
      font-size: 1.25rem !important;
    }

    .d-flex.align-items-center.mb-4 p {
      font-size: 0.875rem !important;
    }

    .d-flex.align-items-center.mb-4 .bg-warning.bg-opacity-10,
    .d-flex.align-items-center.mb-4 .bg-success.bg-opacity-10,
    .d-flex.align-items-center.mb-4 .bg-danger.bg-opacity-10 {
      width: 40px !important;
      height: 40px !important;
    }

    .d-flex.align-items-center.mb-4 .display-6 {
      font-size: 1.25rem !important;
    }

    /* User cards - full width on mobile */
    .row.g-4 > div[class*="col-lg"],
    .row.g-3 > div[class*="col-lg"] {
      width: 100%;
    }

    /* Compact card layouts */
    .card-header {
      padding: 0.75rem !important;
    }

    .card-body {
      padding: 0.75rem !important;
    }

    .card-footer {
      padding: 0.75rem !important;
    }

    /* Handle email overflow */
    .card-body small {
      font-size: 0.75rem !important;
      word-break: break-all;
      line-height: 1.4;
    }

    /* Icon sizing for mobile */
    .display-5 {
      font-size: 2rem !important;
    }

    .display-6 {
      font-size: 1.5rem !important;
    }

    /* Button text wrapping prevention */
    .btn {
      white-space: nowrap;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Dropdown menu improvements */
    .dropdown-menu {
      font-size: 0.9rem;
      min-width: 200px;
    }

    .dropdown-item {
      padding: 0.75rem 1rem !important;
      min-height: 44px;
      display: flex;
      align-items: center;
    }

    .dropdown-toggle {
      min-height: 40px;
      min-width: 40px;
    }

    /* Badge sizing */
    .badge {
      font-size: 0.75rem !important;
      padding: 0.35em 0.65em;
    }

    /* Alert boxes */
    .alert {
      font-size: 0.9rem;
      padding: 0.75rem;
    }

    /* Card header person icon */
    .card-header .bi-person-circle {
      font-size: 2rem !important;
    }

    /* Empty state cards */
    .text-center.py-5 .card-body {
      padding: 2rem 1rem !important;
    }

    .text-center.py-5 .display-1 {
      font-size: 3rem !important;
    }

    /* Grid gap reduction */
    .row.g-4 {
      gap: 1rem !important;
    }

    .row.g-3 {
      gap: 0.75rem !important;
    }
  }

  /* Small phones - extra compact */
  @media (max-width: 375px) {
    h1.display-5 {
      font-size: 1.5rem !important;
    }

    .card-title {
      font-size: 0.95rem !important;
    }

    .btn {
      font-size: 0.875rem;
      padding: 0.5rem 0.75rem;
    }

    .card-body small {
      font-size: 0.7rem !important;
    }

    .display-4 {
      font-size: 1.75rem !important;
    }
  }

  /* Landscape orientation on mobile */
  @media (max-width: 768px) and (orientation: landscape) {
    .row.mb-5 > div[class*="col-md-3"] {
      width: 50%;
      float: left;
    }

    .row.g-4 > div[class*="col-lg"] {
      width: 50%;
      float: left;
    }
  }

  /* Tablet optimization */
  @media (min-width: 769px) and (max-width: 1024px) {
    .row > div.col-lg-6 {
      width: 100%;
    }

    .row > div.col-xl-4 {
      width: 50%;
    }

    .row > div.col-xl-3 {
      width: 33.333%;
    }
  }

  /* Ensure buttons don't wrap text awkwardly */
  @media (max-width: 768px) {
    .btn i {
      margin-right: 0.5rem;
    }

    .btn-sm {
      font-size: 0.875rem;
      padding: 0.5rem 0.75rem;
    }
  }
</style>

<!-- JavaScript for Enhanced UX -->
<script>
  // Auto-refresh page every 2 minutes to check for new registrations
  setTimeout(() => {
    if (<%= @pending_users.count %> === 0) {
      // Only auto-refresh if there are no pending items to avoid interrupting work
      location.reload();
    }
  }, 120000);
  
  // Add confirmation enhancement
  document.addEventListener('DOMContentLoaded', function() {
    const actionButtons = document.querySelectorAll('[data-confirm]');
    actionButtons.forEach(button => {
      button.addEventListener('click', function(e) {
        const userName = this.getAttribute('data-confirm').match(/'([^']+)'/);
        if (userName) {
          // Enhanced styling for confirmation dialogs could go here
        }
      });
    });
  });
</script>