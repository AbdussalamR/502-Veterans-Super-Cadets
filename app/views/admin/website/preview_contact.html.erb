<!-- Admin Preview Banner -->
<div class="alert alert-warning text-center mb-0 rounded-0 border-0 border-bottom" style="position:sticky;top:0;z-index:9999;">
  <i class="bi bi-eye-fill me-2"></i>
  <strong>PREVIEW MODE</strong> — These changes have NOT been published to the live site yet.
  <a href="<%= admin_website_path(tab: 'contact') %>" class="btn btn-sm btn-warning ms-3">Back to Dashboard</a>
  <%= button_to 'Publish Now', admin_publish_website_contact_path,
        method: :post, class: 'btn btn-sm btn-success ms-2',
        data: { turbo_confirm: 'Publish this draft to the live site?' } %>
</div>

<div class="container my-5">
  <h1 style="color:#500000;" class="border-bottom pb-2 mb-4">Contact Us</h1>

  <div class="row mt-4">
    <div class="col-md-6 mb-4 mb-md-0">
      <h3 class="mb-3">Get in Touch</h3>
      <p class="text-muted mb-4">Have questions? Send us an email or reach out to us using the information below.</p>

      <div class="d-flex mb-3">
        <div class="flex-shrink-0" style="color:#500000;"><i class="bi bi-geo-alt-fill fs-4"></i></div>
        <div class="ms-3">
          <h5 class="mb-1 fw-bold">Address</h5>
          <p class="text-muted" style="white-space:pre-line;"><%= @preview_contact_contents['address'] || "1224 TAMU\nCollege Station, TX 77843" %></p>
        </div>
      </div>

      <div class="d-flex mb-3">
        <div class="flex-shrink-0" style="color:#500000;"><i class="bi bi-envelope-fill fs-4"></i></div>
        <div class="ms-3">
          <h5 class="mb-1 fw-bold">Email</h5>
          <p class="text-muted"><%= @preview_contact_contents['email'] || 'choir@tamu.edu' %></p>
        </div>
      </div>

      <div class="d-flex">
        <div class="flex-shrink-0" style="color:#500000;"><i class="bi bi-telephone-fill fs-4"></i></div>
        <div class="ms-3">
          <h5 class="mb-1 fw-bold">Phone</h5>
          <p class="text-muted"><%= @preview_contact_contents['phone'] || '(979) 845-5974' %></p>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <div class="mb-3">
            <label class="form-label">Name</label>
            <input type="text" class="form-control" disabled>
          </div>
          <div class="mb-3">
            <label class="form-label">Email Address</label>
            <input type="email" class="form-control" disabled>
          </div>
          <div class="mb-3">
            <label class="form-label">Message</label>
            <textarea class="form-control" rows="5" disabled></textarea>
          </div>
          <button type="button" class="btn w-100" style="background-color:#500000;color:white;" disabled>Send Message</button>
        </div>
      </div>
    </div>
  </div>
</div>
