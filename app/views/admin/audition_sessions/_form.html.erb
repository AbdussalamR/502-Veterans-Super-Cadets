<%= form_with model: [:admin, audition_session] do |f| %>
  <% if audition_session.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% audition_session.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :label, "Label (e.g. Fall 2026)", class: "form-label" %>
    <%= f.text_field :label, class: "form-control" %>
  </div>

  <div class="row mb-3">
    <div class="col">
      <%= f.label :start_datetime, "Start", class: "form-label" %>
      <%= f.datetime_local_field :start_datetime, class: "form-control" %>
    </div>
    <div class="col">
      <%= f.label :end_datetime, "End", class: "form-label" %>
      <%= f.datetime_local_field :end_datetime, class: "form-control" %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :location, class: "form-label" %>
    <%= f.text_field :location, class: "form-control" %>
  </div>

  <%= f.submit class: "btn btn-maroon border border-primary border-2" %>
<% end %>