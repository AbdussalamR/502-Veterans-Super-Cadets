<div class="container my-5">
  <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-4">
    <h1 class="text-maroon">Audition Sessions</h1>
    <%= link_to "Add Session", new_admin_audition_session_path, class: "btn btn-maroon" %>
  </div>

  <% if @audition_sessions.empty? %>
    <p class="text-muted">No audition sessions have been added yet.</p>
  <% else %>
    <table class="table table-hover">
      <thead>
        <tr>
          <th>Label</th>
          <th>Start</th>
          <th>End</th>
          <th>Location</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @audition_sessions.each do |session| %>
          <tr>
            <td><%= session.label %></td>
            <td><%= session.start_datetime.strftime("%b %-d, %Y %-I:%M %p") %></td>
            <td><%= session.end_datetime.strftime("%b %-d, %Y %-I:%M %p") %></td>
            <td><%= session.location %></td>
            <td class="text-end">
              <%= link_to "Edit", edit_admin_audition_session_path(session), class: "btn btn-sm btn-outline-secondary me-1" %>
              <%= button_to "Delete", admin_audition_session_path(session), method: :delete,
                    data: { turbo_confirm: "Delete this audition session?" },
                    class: "btn btn-sm btn-outline-danger" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>