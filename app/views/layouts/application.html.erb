<!DOCTYPE html>
<html>
<head>
  <title>Singing Cadets</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  
  <%= stylesheet_link_tag 'application', media: 'all', 'data-turbo-track': 'reload' %>
  <%= javascript_importmap_tags %>
  
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
  
  <!-- Mobile-Friendly Styles -->
  <style>
    /* Ensure proper touch targets for mobile */
    @media (max-width: 991.98px) {
      .navbar-nav .nav-link {
        padding: 0.75rem 1rem;
        min-height: 44px;
        display: flex;
        align-items: center;
      }
      
      .dropdown-menu {
        border: none;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
      }
      
      .dropdown-item {
        padding: 0.75rem 1rem;
        min-height: 44px;
      }
      
      /* Better spacing for mobile navbar */
      .navbar-collapse {
        margin-top: 0.5rem;
      }
      
      /* Make badges more visible on mobile */
      .navbar-nav .badge {
        font-size: 0.75rem;
        padding: 0.25em 0.5em;
      }
      
      /* Prevent text wrapping in mobile nav */
      .navbar-nav .nav-link {
        white-space: nowrap;
      }
    }
    
    /* Tablet optimization */
    @media (min-width: 768px) and (max-width: 991.98px) {
      .container {
        max-width: 100%;
        padding-left: 1rem;
        padding-right: 1rem;
      }
    }
    
    /* iPhone and Android specific optimizations */
    @media (max-width: 767.98px) {
      .container {
        padding-left: 0.75rem;
        padding-right: 0.75rem;
      }
      
      .navbar-brand {
        font-size: 1.1rem;
      }
      
      /* Stack flash messages nicely */
      .alert {
        font-size: 0.9rem;
        padding: 0.75rem;
        margin-bottom: 0.75rem;
      }
      
      /* Make close buttons easier to tap */
      .btn-close {
        padding: 0.5rem;
        margin: -0.25rem -0.25rem -0.25rem auto;
      }
    }
    
    /* Prevent zoom on input focus (iOS Safari) */
    @media screen and (max-width: 767.98px) {
      input, select, textarea {
        font-size: 16px !important;
      }
    }
  </style>
  
</head>

<body>
  <% if user_signed_in? %>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
      <div class="container-fluid">
        <%= link_to "Singing Cadets", root_path, class: "navbar-brand" %>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="navbarNav">
        <div class="navbar-nav me-auto">
          <%= link_to "Events", events_path, class: "nav-link" %>
          <%= link_to excuses_path, class: "nav-link d-flex align-items-center" do %>
            Excuses
            <%# Show role-appropriate pending count badges %>
            <% if current_user.super_admin? %>
              <% pending_admin_count = Excuse.pending_admin_approval.count %>
              <% if pending_admin_count > 0 %>
                <span class="badge bg-danger ms-2"><%= pending_admin_count %></span>
              <% end %>
            <% elsif current_user.officer? %>
              <% pending_officer_count = Excuse.pending_unprocessed.count %>
              <% if pending_officer_count > 0 %>
                <span class="badge bg-danger ms-2"><%= pending_officer_count %></span>
              <% end %>
            <% end %>
          <% end %>
          <%= link_to "Music Drive", "https://drive.google.com/drive/u/3/folders/0ACAwK4ezZTfMUk9PVA", class: "nav-link", target: "_blank", rel: "noopener" %>
          
          <% if current_user.admin? %>
            <%= link_to "Member Management", users_path, class: "nav-link" %>
            <%= link_to "Discipline Points", demerits_path, class: "nav-link" %>
            <% pending_registrations = User.pending.count %>
            <%= link_to admin_registrations_path, class: "nav-link d-flex align-items-center" do %>
              Registration Approval
              <% if pending_registrations > 0 %>
                <span class="badge bg-danger ms-2"><%= pending_registrations %></span>
              <% end %>
            <% end %>
          <% elsif current_user.user? %>
            <%= link_to my_demerits_path, class: "nav-link" do %>
              Discipline Points
              <% if current_user.received_demerits.count > 0 %>
                <span class="badge bg-danger"><%= current_user.received_demerits.count %></span>
              <% end %>
            <% end %>
          <% end %>
        </div>
        
        <div class="navbar-nav ms-auto">
          <div class="dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
              <%= current_user.full_name %>
              <span class="badge bg-<%= current_user.super_admin? ? 'danger' : (current_user.officer? ? 'warning' : 'secondary') %> ms-1">
                <%= current_user.role_display_name %>
              </span>
            </a>
            <ul class="dropdown-menu">
              <li><%= link_to "Profile", user_path(current_user), class: "dropdown-item" %></li>
              <li><%= link_to "Help", help_path, class: "dropdown-item" %></li>
              <li><hr class="dropdown-divider"></li>
              <li><%= button_to "Sign out", "/auth/sign_out", method: :delete, class: "dropdown-item", style: "background: none; border: none; width: 100%; text-align: left;" %></li>
            </ul>
          </div>
        </div>
        </div>
      </div>
    </nav>
  <% else %>
    <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #500000;">
      <div class="container-fluid">
        <%= link_to root_path, class: "navbar-brand d-flex align-items-center" do %>
          <!-- Placeholder for Logo -->
          <div class="logo-placeholder me-2" style="width: 40px; height: 40px; background-color: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center;" title="Logo Placeholder">
            <i class="bi bi-music-note-beamed text-white"></i>
          </div>
          <span class="fw-bold">Singing Cadets</span>
        <% end %>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#publicNavbarNav" aria-controls="publicNavbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="publicNavbarNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <%= link_to "Home", root_path, class: "nav-link #{'active fw-bold' if current_page?(root_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Book Us", performance_request_path, class: "nav-link #{'active fw-bold' if current_page?(performance_request_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Media", media_gallery_path, class: "nav-link #{'active fw-bold' if current_page?(media_gallery_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Auditions", audition_information_path, class: "nav-link #{'active fw-bold' if current_page?(audition_information_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Contact", contact_path, class: "nav-link #{'active fw-bold' if current_page?(contact_path)}" %>
            </li>
          </ul>
          
          <div class="navbar-nav ms-auto">
            <%= link_to "Member Login", "/users/sign_in", class: "btn btn-outline-light mt-2 mt-lg-0" %>
          </div>
        </div>
      </div>
    </nav>
  <% end %>

  <div class="container mt-4">
    <% if flash.any? %>
      <% flash.each do |key, value| %>
        <div class="alert alert-<%= key == 'notice' ? 'success' : 'danger' %> alert-dismissible fade show" role="alert">
          <%= value.html_safe %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>
    <% end %>

    <%= yield %>
  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>