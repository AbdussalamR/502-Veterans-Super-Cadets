<!DOCTYPE html>
<html>
<head>
  <title>Singing Cadets</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  
  <%= stylesheet_link_tag 'application', media: 'all', 'data-turbo-track': 'reload' %>
  <%= javascript_importmap_tags %>
  
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
  <link href='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/main.min.css' rel='stylesheet' />
  
  <!-- Mobile-Friendly Styles -->
  <style>
    /* Ensure proper touch targets for mobile */
    @media (max-width: 991.98px) {
      .navbar-nav .nav-link {
        padding: 0.75rem 1rem;
        min-height: 44px;
        display: flex;
        align-items: center;
      }
      
      .dropdown-menu {
        border: none;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
      }
      
      .dropdown-item {
        padding: 0.75rem 1rem;
        min-height: 44px;
      }
      
      /* Better spacing for mobile navbar */
      .navbar-collapse {
        margin-top: 0.5rem;
      }
      
      /* Make badges more visible on mobile */
      .navbar-nav .badge {
        font-size: 0.75rem;
        padding: 0.25em 0.5em;
      }
      
      /* Prevent text wrapping in mobile nav */
      .navbar-nav .nav-link {
        white-space: nowrap;
      }
    }
    
    /* Tablet optimization */
    @media (min-width: 768px) and (max-width: 991.98px) {
      .container {
        max-width: 100%;
        padding-left: 1rem;
        padding-right: 1rem;
      }
    }
    
    /* iPhone and Android specific optimizations */
    @media (max-width: 767.98px) {
      .container {
        padding-left: 0.75rem;
        padding-right: 0.75rem;
      }
      
      .navbar-brand {
        font-size: 1.1rem;
      }
      
      /* Stack flash messages nicely */
      .alert {
        font-size: 0.9rem;
        padding: 0.75rem;
        margin-bottom: 0.75rem;
      }
      
      /* Make close buttons easier to tap */
      .btn-close {
        padding: 0.5rem;
        margin: -0.25rem -0.25rem -0.25rem auto;
      }
    }
    
    /* Prevent zoom on input focus (iOS Safari) */
    @media screen and (max-width: 767.98px) {
      input, select, textarea {
        font-size: 16px !important;
      }
    }
  </style>
  
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #500000;">
      <div class="container-fluid">
        <%= link_to root_path, class: "navbar-brand d-flex align-items-center" do %>
          <!-- Placeholder for Logo -->
          <div class="logo-placeholder me-2" style="width: 40px; height: 40px; background-color: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center;" title="Logo Placeholder">
            <i class="bi bi-music-note-beamed text-white"></i>
          </div>
          <span class="fw-bold">Singing Cadets</span>
        <% end %>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#publicNavbarNav" aria-controls="publicNavbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="publicNavbarNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <%= link_to "Home", public_home_path, class: "nav-link #{'active fw-bold' if current_page?(public_home_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Book Us", public_performance_request_path, class: "nav-link #{'active fw-bold' if current_page?(public_performance_request_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Media", public_media_gallery_path, class: "nav-link #{'active fw-bold' if current_page?(public_media_gallery_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Auditions", public_audition_information_path, class: "nav-link #{'active fw-bold' if current_page?(public_audition_information_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Calendar", public_calendar_path, class: "nav-link #{'active fw-bold' if current_page?(public_calendar_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Contact", public_contact_path, class: "nav-link #{'active fw-bold' if current_page?(public_contact_path)}" %>
            </li>
          </ul>
          
          <div class="navbar-nav ms-auto">
            <%= link_to "Member Login", "/users/sign_in", class: "btn btn-outline-light mt-2 mt-lg-0" %>
          </div>
        </div>
      </div>
    </nav>

  <div class="container mt-4">
    <% if flash.any? %>
      <% flash.each do |key, value| %>
        <div class="alert alert-<%= key == 'notice' ? 'success' : 'danger' %> alert-dismissible fade show" role="alert">
          <%= value.html_safe %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>
    <% end %>

    <%= yield %>
  </div>

  <!-- Footer -->
  <footer class="mt-5 py-4" style="background-color: #500000; color: #fff;">
    <div class="container text-center">
      <p class="mb-2 fw-bold">The Singing Cadets &mdash; The Voice of Aggieland</p>
      <div class="d-flex justify-content-center gap-4 mb-2">
        <a href="https://www.instagram.com/singingcadets" target="_blank" rel="noopener" class="text-white" aria-label="Singing Cadets on Instagram">
          <i class="bi bi-instagram fs-5" aria-hidden="true"></i>
        </a>
        <a href="https://www.youtube.com/@SingingCadets" target="_blank" rel="noopener" class="text-white" aria-label="Singing Cadets on YouTube">
          <i class="bi bi-youtube fs-5" aria-hidden="true"></i>
        </a>
        <a href="https://twitter.com/SingingCadets" target="_blank" rel="noopener" class="text-white" aria-label="Singing Cadets on X (Twitter)">
          <i class="bi bi-twitter fs-5" aria-hidden="true"></i>
        </a>
      </div>
      <p class="mb-0 small text-white-50">&copy; <%= Time.current.year %> Texas A&amp;M University Singing Cadets</p>
    </div>
  </footer>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>