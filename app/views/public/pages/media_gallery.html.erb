<div class="container my-5">
  <h1 class="text-maroon border-bottom pb-2 mb-4">Media Gallery</h1>

  <p class="text-muted mb-4">Listen to our music and see moments from our latest performances.</p>

  <ul class="nav nav-tabs mb-4" id="mediaTabs" role="tablist">
    <li class="nav-item" role="presentation">
      <button class="nav-link active text-dark" id="photos-tab" data-bs-toggle="tab" data-bs-target="#photos" type="button" role="tab" aria-controls="photos" aria-selected="true">Photos</button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link text-dark" id="videos-tab" data-bs-toggle="tab" data-bs-target="#videos" type="button" role="tab" aria-controls="videos" aria-selected="false">Videos</button>
    </li>
  </ul>

  <div class="tab-content" id="mediaTabsContent">

    <!-- Photos Tab -->
    <div class="tab-pane fade show active" id="photos" role="tabpanel" aria-labelledby="photos-tab">
      <% if @media_photos.any? %>
        <div class="row g-4">
          <% @media_photos.each do |photo| %>
            <div class="col-md-4 col-sm-6">
              <div class="card h-100 border-0 shadow-sm">
                <a href="#" class="photo-lightbox-trigger"
                   data-img-src="<%= url_for(photo.image) %>"
                   data-caption="<%= photo.caption %>"
                   data-bs-toggle="modal" data-bs-target="#photoLightboxModal"
                   style="cursor:pointer;">
                  <%= image_tag photo.image,
                        class: 'card-img-top',
                        style: 'height: 200px; object-fit: cover;',
                        alt: photo.caption.presence || 'Singing Cadets photo' %>
                </a>
                <% if photo.caption.present? %>
                  <div class="card-body p-2">
                    <p class="card-text small text-muted mb-0"><%= photo.caption %></p>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="row g-4">
          <% 6.times do %>
            <div class="col-md-4">
              <div class="card h-100 border-0 shadow-sm">
                <div class="bg-secondary" style="height: 200px; display: flex; align-items: center; justify-content: center;" role="img" aria-label="Photo placeholder">
                  <i class="bi bi-image text-white" style="font-size: 2rem;" aria-hidden="true"></i>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Videos Tab -->
    <div class="tab-pane fade" id="videos" role="tabpanel" aria-labelledby="videos-tab">
      <% if @media_videos.any? %>
        <div class="row g-4">
          <% @media_videos.each do |video| %>
            <div class="col-md-6">
              <div class="card h-100 border-0 shadow-sm">
                <div class="ratio ratio-16x9">
                  <iframe src="<%= video.embed_url %>"
                          title="<%= video.title.presence || 'Singing Cadets video' %>"
                          frameborder="0"
                          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                          allowfullscreen></iframe>
                </div>
                <% if video.title.present? %>
                  <div class="card-body p-3">
                    <p class="card-text fw-semibold mb-0"><%= video.title %></p>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="row g-4">
          <% 3.times do %>
            <div class="col-md-6">
              <div class="card h-100 border-0 shadow-sm">
                <div class="bg-dark" style="height: 300px; display: flex; align-items: center; justify-content: center;" role="img" aria-label="Video placeholder">
                  <i class="bi bi-play-circle text-white" style="font-size: 3rem;" aria-hidden="true"></i>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

  </div>
</div>

<!-- Photo Lightbox Modal -->
<div class="modal fade" id="photoLightboxModal" tabindex="-1" aria-labelledby="photoLightboxModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content bg-dark border-0">
      <div class="modal-header border-0 py-2">
        <h2 id="photoLightboxModalLabel" class="visually-hidden">Photo enlarged view</h2>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-center p-0 p-md-2">
        <img id="lightboxImg" src="" alt="" class="img-fluid rounded" style="max-height: 80vh; object-fit: contain;">
      </div>
      <div class="modal-footer border-0 justify-content-center py-2">
        <p id="lightboxCaption" class="text-white-50 mb-0 small"></p>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.photo-lightbox-trigger').forEach(function (link) {
      link.addEventListener('click', function (e) {
        e.preventDefault();
        document.getElementById('lightboxImg').src     = this.dataset.imgSrc;
        document.getElementById('lightboxImg').alt     = this.dataset.caption || '';
        document.getElementById('lightboxCaption').textContent = this.dataset.caption || '';
      });
    });
  });
</script>
