<div class="container my-5">
  <h1 class="text-maroon border-bottom pb-2 mb-4">Media Gallery</h1>
  
  <p class="text-muted mb-4">Listen to our music and see moments from our latest performances.</p>

  <ul class="nav nav-tabs mb-4" id="mediaTabs" role="tablist">
    <li class="nav-item" role="presentation">
      <button class="nav-link active text-dark" id="photos-tab" data-bs-toggle="tab" data-bs-target="#photos" type="button" role="tab">Photos</button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link text-dark" id="videos-tab" data-bs-toggle="tab" data-bs-target="#videos" type="button" role="tab">Videos</button>
    </li>
  </ul>

  <div class="tab-content" id="mediaTabsContent">
    <div class="tab-pane fade show active" id="photos" role="tabpanel">
      <div class="row g-4">
        <% 6.times do %>
          <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
              <div class="bg-secondary" style="height: 200px; display: flex; align-items: center; justify-content: center;" role="img" aria-label="Photo placeholder">
                <i class="bi bi-image text-white" style="font-size: 2rem;" aria-hidden="true"></i>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
    <div class="tab-pane fade" id="videos" role="tabpanel">
      <div class="row g-4">
        <% 3.times do %>
          <div class="col-md-6">
            <div class="card h-100 border-0 shadow-sm">
              <div class="bg-dark" style="height: 300px; display: flex; align-items: center; justify-content: center;" role="img" aria-label="Video placeholder">
                <i class="bi bi-play-circle text-white" style="font-size: 3rem;" aria-hidden="true"></i>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
