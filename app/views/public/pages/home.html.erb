<div class="public-page-wrapper">
  
  <!-- Hero Section -->
  <div class="hero-section text-center text-white d-flex align-items-center justify-content-center flex-column" style="min-height: 50vh; background-color: #500000;">
    <h1 class="display-3 fw-bold mb-4">The Singing Cadets</h1>
    <p class="lead mb-4">The Voice of Aggieland</p>
    <%= link_to "Book a Performance", public_performance_request_path, class: "btn btn-outline-light btn-lg" %>
  </div>

  <!-- About Section -->
  <div class="container my-5">
    <div class="row align-items-center">
      <div class="col-md-6">
        <h2 class="text-maroon fw-bold mb-3">About Us</h2>
        <p>
          Internationally known as the "Voice of Aggieland", the Singing Cadets is Texas A&M University's premier men's chorus. 
          We are one of the oldest student organizations on campus, representing the university through music and performance across the state, nation, and world.
        </p>
      </div>
      <div class="col-md-6 text-center">
        <!-- Placeholder for a group photo -->
        <div class="bg-light p-5 border rounded" style="min-height: 250px; display: flex; align-items: center; justify-content: center;">
          <span class="text-muted"><i class="bi bi-camera me-2"></i>Choir Photo Placeholder</span>
        </div>
      </div>
    </div>
  </div>

</div>
