<% # Pass @performance_request from controller for validation errors and field re-population %>
<% @performance_request ||= PerformanceRequest.new %>

<div class="container my-5">
  <h1 class="text-maroon border-bottom pb-2 mb-4">Request a Performance</h1>

  <div class="row">
    <div class="col-md-8">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <p class="text-muted mb-4">
            Interested in having the Singing Cadets perform at your event?
            Fill out the form below and our Director will be in touch.
          </p>

          <%# SCRUM-75: Show field-level validation errors %>
          <% if @performance_request.errors.any? %>
            <div class="alert alert-danger" role="alert">
              <strong>Please fix the following errors:</strong>
              <ul class="mb-0 mt-2">
                <% @performance_request.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with model: @performance_request,
                        url: public_submit_performance_request_path,
                        method: :post,
                        local: true do |f| %>

            <%# Helper: highlight field red if it has an error %>
            <%
              def field_class(obj, attr)
                obj.errors[attr].any? ? "form-control is-invalid" : "form-control"
              end
            %>

            <!-- SCRUM-22: Required field — Name -->
            <div class="mb-3">
              <%= f.label :name, "Full Name", class: "form-label fw-bold" %>
              <%= f.text_field :name,
                    class: (@performance_request.errors[:name].any? ? "form-control is-invalid" : "form-control"),
                    placeholder: "Jane Smith",
                    required: true %>
              <% if @performance_request.errors[:name].any? %>
                <div class="invalid-feedback"><%= @performance_request.errors[:name].first %></div>
              <% end %>
            </div>

            <!-- SCRUM-22: Required field — Organization -->
            <div class="mb-3">
              <%= f.label :organization, "Organization / Company", class: "form-label fw-bold" %>
              <%= f.text_field :organization,
                    class: (@performance_request.errors[:organization].any? ? "form-control is-invalid" : "form-control"),
                    placeholder: "Texas A&M University",
                    required: true %>
              <% if @performance_request.errors[:organization].any? %>
                <div class="invalid-feedback"><%= @performance_request.errors[:organization].first %></div>
              <% end %>
            </div>

            <!-- SCRUM-22: Required field — Event Date (SCRUM-75: must be future) -->
            <div class="mb-3">
              <%= f.label :event_date, "Event Date", class: "form-label fw-bold" %>
              <%= f.date_field :event_date,
                    class: (@performance_request.errors[:event_date].any? ? "form-control is-invalid" : "form-control"),
                    min: Date.tomorrow.to_s,
                    required: true %>
              <div class="form-text text-muted">Must be a future date.</div>
              <% if @performance_request.errors[:event_date].any? %>
                <div class="invalid-feedback"><%= @performance_request.errors[:event_date].first %></div>
              <% end %>
            </div>

            <!-- SCRUM-22: Required field — Location -->
            <div class="mb-3">
              <%= f.label :location, "Event Location", class: "form-label fw-bold" %>
              <%= f.text_field :location,
                    class: (@performance_request.errors[:location].any? ? "form-control is-invalid" : "form-control"),
                    placeholder: "Kyle Field, College Station, TX",
                    required: true %>
              <% if @performance_request.errors[:location].any? %>
                <div class="invalid-feedback"><%= @performance_request.errors[:location].first %></div>
              <% end %>
            </div>

            <!-- SCRUM-22: Required field — Contact Email -->
            <div class="mb-3">
              <%= f.label :contact_email, "Contact Email", class: "form-label fw-bold" %>
              <%= f.email_field :contact_email,
                    class: (@performance_request.errors[:contact_email].any? ? "form-control is-invalid" : "form-control"),
                    placeholder: "jane.smith@example.com",
                    required: true %>
              <% if @performance_request.errors[:contact_email].any? %>
                <div class="invalid-feedback"><%= @performance_request.errors[:contact_email].first %></div>
              <% end %>
            </div>

            <!-- Optional: Additional Notes -->
            <div class="mb-4">
              <%= f.label :notes, "Additional Notes (optional)", class: "form-label fw-bold" %>
              <%= f.text_area :notes,
                    class: "form-control",
                    rows: 3,
                    placeholder: "Anything else we should know about your event..." %>
            </div>

            <%= f.submit "Submit Request",
                  class: "btn btn-maroon px-4 py-2",
                  id: "submit-performance-request" %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-md-4 mt-4 mt-md-0">
      <div class="card border-0 bg-light p-3">
        <h5 class="fw-bold mb-3"><i class="bi bi-info-circle text-maroon me-2"></i>Booking Information</h5>
        <ul class="list-unstyled">
          <li class="mb-3"><strong>Notice:</strong> Please submit requests at least 4 weeks in advance.</li>
          <li class="mb-3"><strong>Required:</strong> Name, Organization, Event Date, Location, and Contact Email.</li>
          <li class="mb-3"><strong>Response Time:</strong> Our Director reviews all requests and typically responds within 5–7 business days.</li>
          <li><strong>Inquiries:</strong> For direct questions, visit our <%= link_to 'Contact page', public_contact_path %>.</li>
        </ul>
      </div>
    </div>
  </div>
</div>
