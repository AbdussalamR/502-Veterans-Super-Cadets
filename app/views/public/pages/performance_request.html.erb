<div class="container my-5">
  <h1 class="text-maroon border-bottom pb-2 mb-4">Performance Request</h1>
  
  <div class="row">
    <div class="col-md-8">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <p class="text-muted mb-4">Interested in having the Singing Cadets perform at your event? Please fill out the form below.</p>
          
          <form>
            <div class="row mb-3">
              <div class="col-md-6">
                <label class="form-label fw-bold">First Name</label>
                <input type="text" class="form-control" placeholder="John">
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold">Last Name</label>
                <input type="text" class="form-control" placeholder="Doe">
              </div>
            </div>
            
            <div class="mb-3">
              <label class="form-label fw-bold">Email</label>
              <input type="email" class="form-control" placeholder="john.doe@example.com">
            </div>

            <div class="mb-3">
              <label class="form-label fw-bold">Event Type</label>
              <select class="form-select">
                <option>Corporate Event</option>
                <option>Private Party</option>
                <option>University Event</option>
                <option>Other</option>
              </select>
            </div>
            
            <div class="mb-3">
              <label class="form-label fw-bold">Event Details</label>
              <textarea class="form-control" rows="4" placeholder="Tell us more about your event..."></textarea>
            </div>
            
            <button type="button" class="btn btn-maroon px-4 py-2 mt-2">Submit Request</button>
          </form>
        </div>
      </div>
    </div>
    
    <div class="col-md-4 mt-4 mt-md-0">
      <div class="card border-0 bg-light p-3">
        <h5 class="fw-bold mb-3"><i class="bi bi-info-circle text-maroon me-2"></i> Booking Information</h5>
        <ul class="list-unstyled">
          <li class="mb-3"><strong>Notice:</strong> Please submit requests at least 4 weeks in advance.</li>
          <li class="mb-3"><strong>Pricing:</strong> Pricing varies based on event length and location.</li>
          <li>For direct inquiries, contact our management team on the <%= link_to 'Contact page', public_contact_path %>.</li>
        </ul>
      </div>
    </div>
  </div>
</div>
