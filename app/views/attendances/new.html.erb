<h1>Take Attendance for <%= @event.title %></h1>
<p>Date: <%= @event.date.strftime("%B %d, %Y") %></p>

<% if @excused_user_ids.any? %>
  <div class="alert alert-warning" role="alert">
    <i class="bi bi-info-circle me-2"></i>
    <strong><%= @excused_user_ids.count %></strong> <%= 'student'.pluralize(@excused_user_ids.count) %> <%= 'has'.pluralize(@excused_user_ids.count) %> approved excuses and will be marked as excused (locked).
  </div>
<% end %>

<%= form_tag event_attendances_path(@event), method: :post do %>
  <table border="1" style="width: 100%; border-collapse: collapse; margin-top: 20px;">
    <tr>
      <th>Name</th>
      <th>Present</th>
      <th>Tardy</th>
      <th>Excused</th>
      <th>Absent</th>
      <th>Note</th>
    </tr>
    
    <% @users.each do |user| %>
      <% current_status = @attendances[user.id]&.status || 'absent' %>
      <% is_excused = @excused_user_ids.include?(user.id) %>
      <tr style="<%= 'background-color: #f8f9fa; opacity: 0.7;' if is_excused %>">
        <td>
          <%= user.full_name %>
          <% if is_excused %>
            <span class="badge bg-warning text-dark ms-2">
              <i class="bi bi-file-earmark-check me-1"></i>Approved Excuse
            </span>
          <% end %>
        </td>
        <td style="text-align: center;">
          <%= radio_button_tag "attendances[#{user.id}][status]", "present", current_status == "present", disabled: is_excused %>
        </td>
        <td style="text-align: center;">
          <%= radio_button_tag "attendances[#{user.id}][status]", "tardy", current_status == "tardy", disabled: is_excused %>
        </td>
        <td style="text-align: center;">
          <%= radio_button_tag "attendances[#{user.id}][status]", "excused", current_status == "excused", disabled: is_excused %>
        </td>
        <td style="text-align: center;">
          <%= radio_button_tag "attendances[#{user.id}][status]", "absent", current_status == "absent", disabled: is_excused %>
        </td>
        <td>
          <%= text_field_tag "attendances[#{user.id}][note]", @attendances[user.id]&.note, placeholder: "Optional note", disabled: is_excused %>
        </td>
      </tr>
    <% end %>
  </table>
  
  <div style="margin-top: 20px;" class="d-flex gap-2">
    <button type="submit" class="btn btn-primary" id="save-attendance-btn">
      <i class="bi bi-save me-2"></i>Save Attendance
    </button>
    
    <%= link_to @event, id: "cancel-button", class: "btn btn-outline-secondary" do %>
      <i class="bi bi-x-circle me-2"></i>Cancel
    <% end %>
  </div>
<% end %>

<!-- Confirmation Modal -->
<div class="modal fade" id="cancelConfirmModal" tabindex="-1" aria-labelledby="cancelConfirmModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-warning bg-opacity-10">
        <h5 class="modal-title" id="cancelConfirmModalLabel">
          <i class="bi bi-exclamation-triangle-fill me-2 text-warning"></i>Unsaved Changes
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p>You have unsaved attendance changes for <strong><%= @event.title %></strong>.</p>
        <p>If you leave without saving, your attendance records will not be updated.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
          <i class="bi bi-arrow-return-left me-2"></i>Continue Editing
        </button>
        <a href="<%= event_path(@event) %>" class="btn btn-danger" id="discard-changes-btn">
          <i class="bi bi-x-circle me-2"></i>Discard Changes
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  // Ensure Bootstrap is available
  function ensureBootstrap() {
    if (typeof bootstrap === 'undefined') {
      console.error('Bootstrap is not available');
      return false;
    }
    return true;
  }

  document.addEventListener('DOMContentLoaded', function() {
    let formChanged = false;
    const form = document.querySelector('form');
    const cancelButton = document.getElementById('cancel-button');
    const originalFormState = getFormState();
    
    // Track changes to radio buttons and text fields
    document.querySelectorAll('input[type="radio"], input[type="text"]').forEach(input => {
      input.addEventListener('change', function() {
        const currentFormState = getFormState();
        formChanged = (JSON.stringify(originalFormState) !== JSON.stringify(currentFormState));
        
        // Enable or disable beforeunload warning based on form state
        if (formChanged) {
          window.addEventListener('beforeunload', beforeUnloadHandler);
        } else {
          window.removeEventListener('beforeunload', beforeUnloadHandler);
        }
      });
    });
    
    // Modify the cancel button behavior
    cancelButton.addEventListener('click', function(e) {
      if (!formChanged) {
        // No changes, navigate directly to the event page
        e.preventDefault();
        window.location.href = '<%= event_path(@event) %>';
      } else {
        // If changes exist, show the confirmation modal
        e.preventDefault();
        if (ensureBootstrap()) {
          const modalElement = document.getElementById('cancelConfirmModal');
          // Check if modal is already initialized
          let modal = bootstrap.Modal.getInstance(modalElement);
          if (!modal) {
            modal = new bootstrap.Modal(modalElement, {
              backdrop: 'static', // Prevents closing when clicking outside
              keyboard: true // Allows ESC key to close the modal
            });
          }
          modal.show();
        } else {
          // Fallback if Bootstrap is not available
          if (confirm('You have unsaved changes. Are you sure you want to leave without saving?')) {
            window.location.href = '<%= event_path(@event) %>';
          }
        }
      }
    });
    
    // Add interceptors for any links on the page
    document.querySelectorAll('a:not(#cancel-button):not(#discard-changes-btn)').forEach(link => {
      link.addEventListener('click', function(e) {
        if (formChanged) {
          e.preventDefault();
          // Store the intended destination URL
          document.getElementById('discard-changes-btn').href = this.href;
          
          if (ensureBootstrap()) {
            const modalElement = document.getElementById('cancelConfirmModal');
            // Check if modal is already initialized
            let modal = bootstrap.Modal.getInstance(modalElement);
            if (!modal) {
              modal = new bootstrap.Modal(modalElement, {
                backdrop: 'static', // Prevents closing when clicking outside
                keyboard: true // Allows ESC key to close the modal
              });
            }
            modal.show();
          } else {
            // Fallback if Bootstrap is not available
            if (confirm('You have unsaved changes. Are you sure you want to leave without saving?')) {
              window.location.href = this.href;
            }
          }
        }
      });
    });
    
    // Initialize the beforeunload event based on initial form state
    // We'll only add it once the form has changed
    if (formChanged) {
      window.addEventListener('beforeunload', beforeUnloadHandler);
    } else {
      window.removeEventListener('beforeunload', beforeUnloadHandler);
    }
    
    // Handle form submission to clear the beforeunload event
    form.addEventListener('submit', function() {
      // Remove the beforeunload event handler when form is being submitted
      window.removeEventListener('beforeunload', beforeUnloadHandler);
      // Set formChanged to false to prevent any other handlers from triggering
      formChanged = false;
    });
    
    // Also handle the Save Attendance button directly
    document.getElementById('save-attendance-btn').addEventListener('click', function() {
      // Remove the beforeunload event handler when saving
      window.removeEventListener('beforeunload', beforeUnloadHandler);
      // Set formChanged to false to prevent any other handlers from triggering
      formChanged = false;
    });
    
    // Handle the modal's discard changes button
    document.getElementById('discard-changes-btn').addEventListener('click', function(e) {
      e.preventDefault();
      
      // Get the destination URL
      const destination = this.getAttribute('href');
      
      // Remove the beforeunload event handler
      window.removeEventListener('beforeunload', beforeUnloadHandler);
      
      // Reset the form change tracking
      formChanged = false;
      
      // Hide the modal explicitly before navigation
      if (ensureBootstrap()) {
        const modalElement = document.getElementById('cancelConfirmModal');
        const modalInstance = bootstrap.Modal.getInstance(modalElement);
        if (modalInstance) {
          modalInstance.hide();
          
          // Remove the modal backdrop
          const backdrops = document.getElementsByClassName('modal-backdrop');
          for (let i = 0; i < backdrops.length; i++) {
            backdrops[i].parentNode.removeChild(backdrops[i]);
          }
          
          // Ensure modal classes are removed from body
          document.body.classList.remove('modal-open');
          document.body.style.paddingRight = '';
        }
      }
      
      // Navigate to the destination
      window.location.href = destination;
    });
    
    // Helper function to get current form state
    function getFormState() {
      const state = {};
      document.querySelectorAll('input[type="radio"]:checked, input[type="text"]').forEach(input => {
        if (input.type === 'radio') {
          if (!state[input.name]) state[input.name] = {};
          state[input.name] = input.value;
        } else {
          state[input.name] = input.value;
        }
      });
      return state;
    }
    
    // Browser's native beforeunload handler
    function beforeUnloadHandler(e) {
      e.preventDefault();
      // Standard message - browsers might show their own message instead
      e.returnValue = 'You have unsaved changes. Are you sure you want to leave?';
      return e.returnValue;
    }
  });
</script>
