# Google OAuth2 Configuration (REQUIRED)
# Get these from https://console.cloud.google.com/
# 1. Create a project or select existing
# 2. Enable Google+ API
# 3. Configure OAuth consent screen
# 4. Create OAuth 2.0 Client ID (Web application type)
# 5. Add authorized redirect URI: http://localhost:3000/auth/google_oauth2/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Database Configuration (REQUIRED for local development)
# Default PostgreSQL user is usually 'postgres' or your Windows username
# If you don't have a password set, leave DATABASE_PASSWORD empty
DATABASE_USER=postgres
DATABASE_PASSWORD=your_database_password_here

# Super Admin Emails (Optional - comma-separated list)
# SUPER_ADMIN_EMAILS=admin1@tamu.edu,admin2@tamu.edu
